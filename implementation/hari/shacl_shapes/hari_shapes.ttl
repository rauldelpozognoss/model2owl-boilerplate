core-shape:hari-AttributeAdditionShape a sh:NodeShape ;
    rdfs:label "Attribute Addition" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari-AttributeAddition-hari-hasNewPropertyIRI ;
    sh:targetClass hari:AttributeAddition .

core-shape:hari-AttributeExtensionShape a sh:NodeShape ;
    rdfs:label "Attribute Extension" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari-AttributeExtension-hari-hasAddedProperty ;
    sh:targetClass hari:AttributeExtension .

core-shape:hari-CardinalityExtensionShape a sh:NodeShape ;
