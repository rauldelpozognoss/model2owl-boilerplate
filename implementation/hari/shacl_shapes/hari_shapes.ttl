    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari-CardinalityExtension-hari-hasCardinalityChanged ;
    sh:targetClass hari:CardinalityExtension .

core-shape:hari-CardinalityModificationShape a sh:NodeShape ;
    rdfs:label "Cardinality Modification" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari-CardinalityModification-hari-hasNewMax,
        core-shape:hari-CardinalityModification-hari-hasNewMin,
        core-shape:hari-CardinalityModification-hari-hasOldMax,
        core-shape:hari-CardinalityModification-hari-hasOldMin,
        core-shape:hari-CardinalityModification-hari-hasPropertyIRI ;
    sh:targetClass hari:CardinalityModification .

core-shape:hari-ClassReuseShape a sh:NodeShape ;
