@prefix core-shape: <http://hari-meta.org/data-shape/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hari: <http://hari-meta.org/ontology/hari#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:hari-AllValuesFromShape a sh:NodeShape ;
    rdfs:label "All Values From" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hari:AllValuesFrom .

core-shape:hari-ApplicationShape a sh:NodeShape ;
    rdfs:label "Application" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hari:Application .

core-shape:hari-CardinalityRestrictionShape a sh:NodeShape ;
    rdfs:label "Cardinality Restriction" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:sparql [ sh:select """SELECT ?this WHERE { ?this a <http://hari-meta.org/ontology/hari#CardinalityRestriction> .
                }""" ] ;
    sh:targetClass hari:CardinalityRestriction .

core-shape:hari-ClassShape a sh:NodeShape ;
    rdfs:label "Class" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari-Class-hari-hasClassExpression,
        core-shape:hari-Class-hari-hasDisjointWith,
        core-shape:hari-Class-hari-hasEquivalentTo,
        core-shape:hari-Class-hari-hasSubClassOf ;
    sh:targetClass hari:Class .

core-shape:hari-ComplementShape a sh:NodeShape ;
