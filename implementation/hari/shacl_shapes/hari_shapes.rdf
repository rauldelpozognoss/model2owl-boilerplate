    <sh:select>SELECT ?this ?that WHERE { ?this &lt;http://hari-meta.org/ontology/hari#hasDisjointWith&gt; ?that . ?that &lt;http://hari-meta.org/ontology/hari#hasDisjointWith&gt; ?this .}</sh:select>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Ndab299fa5a9e4ab9b890a5c42d24787e">
    <sh:select>SELECT ?this WHERE { ?this a &lt;http://hari-meta.org/ontology/hari#OntologicalTerm&gt; .
                }</sh:select>
  </rdf:Description>
</rdf:RDF>
