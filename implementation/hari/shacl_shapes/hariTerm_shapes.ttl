@prefix core-shape: <http://hari-meta.org/data-shape/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hariterm: <http://hari-meta.org/ontology/hariterm#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:hariterm-ClassShape a sh:NodeShape ;
    rdfs:label "Class" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hariterm-Class-hariterm-hasDisjointWith,
        core-shape:hariterm-Class-hariterm-hasEquivalentTo,
        core-shape:hariterm-Class-hariterm-hasSubClassOf ;
    sh:targetClass hariterm:Class .

core-shape:hariterm-DatatypeShape a sh:NodeShape ;
    rdfs:label "Datatype" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hariterm:Datatype .

core-shape:hariterm-OntologicalTermShape a sh:NodeShape ;
    rdfs:label "Ontological Term" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hariterm-OntologicalTerm-hariterm-hasTermDefinition,
        core-shape:hariterm-OntologicalTerm-hariterm-hasTermExample,
        core-shape:hariterm-OntologicalTerm-hariterm-hasTermIRI,
        core-shape:hariterm-OntologicalTerm-hariterm-hasTermLabel ;
    sh:sparql [ sh:select """SELECT ?this WHERE { ?this a <http://hari-meta.org/ontology/hariterm#OntologicalTerm> .
                }""" ] ;
    sh:targetClass hariterm:OntologicalTerm .

core-shape:hariterm-PropertyShape a sh:NodeShape ;
    rdfs:label "Property" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hariterm-Property-hariterm-hasAnotationPropertyDomainClassAnotation,
        core-shape:hariterm-Property-hariterm-hasAnotationPropertyDomainDatatypeAnotation,
        core-shape:hariterm-Property-hariterm-hasAnotationPropertyDomainPropertyAnotation,
        core-shape:hariterm-Property-hariterm-hasDatatypePropertyDomainDatatype,
        core-shape:hariterm-Property-hariterm-hasDatatypePropertyRangeDatatype,
        core-shape:hariterm-Property-hariterm-hasObjectPropertyChain,
        core-shape:hariterm-Property-hariterm-hasObjectPropertyDomainClass,
        core-shape:hariterm-Property-hariterm-hasObjectPropertyInverseOf,
        core-shape:hariterm-Property-hariterm-hasObjectPropertyRangeClass,
        core-shape:hariterm-Property-hariterm-hasSubPropertyOf,
        core-shape:hariterm-Property-hariterm-isAssymetric,
        core-shape:hariterm-Property-hariterm-isFunctional,
        core-shape:hariterm-Property-hariterm-isInverseFunctional,
        core-shape:hariterm-Property-hariterm-isIrreflexive,
        core-shape:hariterm-Property-hariterm-isReflexive,
        core-shape:hariterm-Property-hariterm-isSymmetric,
        core-shape:hariterm-Property-hariterm-isTransitive ;
    sh:targetClass hariterm:Property .

core-shape:hariterm-Class-hariterm-hasDisjointWith a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class hariterm:Class ;
    sh:name "Has disjoint with" ;
    sh:path hariterm:hasDisjointWith ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://hari-meta.org/ontology/hariterm#hasDisjointWith> ?that . ?that <http://hari-meta.org/ontology/hariterm#hasDisjointWith> ?this .}" ] .

