@prefix core-shape: <http://hari-meta.org/data-shape/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hari_project: <http://hari-meta.org/ontology/hari_project#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:hari_project-OntologyProjectShape a sh:NodeShape ;
    rdfs:label "Ontology Project" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari_project-OntologyProject-hari_project-hasAcronym,
        core-shape:hari_project-OntologyProject-hari_project-hasDescription,
        core-shape:hari_project-OntologyProject-hari_project-hasOntologyIRI,
        core-shape:hari_project-OntologyProject-hari_project-hasOrganization,
        core-shape:hari_project-OntologyProject-hari_project-hasTitle ;
    sh:targetClass hari_project:OntologyProject .

core-shape:hari_project-ThingShape a sh:NodeShape ;
    rdfs:label "Thing" ;
    rdfs:comment "Clase raíz del metamodelo. Todas las clases diseñadas cuelgan de aquí." ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hari_project:Thing .

core-shape:hari_project-OntologyProject-hari_project-hasAcronym a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has acronym" ;
    sh:path hari_project:hasAcronym .

core-shape:hari_project-OntologyProject-hari_project-hasDescription a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has description" ;
    sh:path hari_project:hasDescription .

core-shape:hari_project-OntologyProject-hari_project-hasOntologyIRI a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has ontology IRI" ;
    sh:path hari_project:hasOntologyIRI .

core-shape:hari_project-OntologyProject-hari_project-hasOrganization a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has organization" ;
    sh:path hari_project:hasOrganization .

core-shape:hari_project-OntologyProject-hari_project-hasTitle a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has title" ;
    sh:path hari_project:hasTitle .

core-shape:core-shape a owl:Ontology ;
    rdfs:label "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:issued "2026-04-20"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Shapes"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from hari_project.xml on 2026-04-20" ;
    owl:imports hari_project:core,
        hari_project:core-restriction,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/data-shape/hari#core-shape-" ;
    owl:versionIRI core-shape:core-shape-1.0.0 ;
    owl:versionInfo "1.0.0" .

