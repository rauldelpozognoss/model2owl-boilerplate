@prefix core-shape: <http://hari-meta.org/data-shape/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fhariterm: <http://hari-meta.org/ontology/fhariterm#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:fhariterm-ClassShape a sh:NodeShape ;
    rdfs:label "Class" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:fhariterm-Class-fhariterm-hasDisjointWith,
        core-shape:fhariterm-Class-fhariterm-hasEquivalentTo,
        core-shape:fhariterm-Class-fhariterm-hasSubClassOf ;
    sh:targetClass fhariterm:Class .

core-shape:fhariterm-DatatypeShape a sh:NodeShape ;
    rdfs:label "Datatype" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass fhariterm:Datatype .

core-shape:fhariterm-OntologicalTermShape a sh:NodeShape ;
    rdfs:label "Ontological Term" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:fhariterm-OntologicalTerm-fhariterm-hasTermDefinition,
        core-shape:fhariterm-OntologicalTerm-fhariterm-hasTermExample,
        core-shape:fhariterm-OntologicalTerm-fhariterm-hasTermIRI,
        core-shape:fhariterm-OntologicalTerm-fhariterm-hasTermLabel ;
    sh:sparql [ sh:select """SELECT ?this WHERE { ?this a <http://hari-meta.org/ontology/fhariterm#OntologicalTerm> .
                }""" ] ;
    sh:targetClass fhariterm:OntologicalTerm .

core-shape:fhariterm-PropertyShape a sh:NodeShape ;
    rdfs:label "Property" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:fhariterm-Property-fhariterm-hasAnotationPropertyDomainClassAnotation,
        core-shape:fhariterm-Property-fhariterm-hasAnotationPropertyDomainDatatypeAnotation,
        core-shape:fhariterm-Property-fhariterm-hasAnotationPropertyDomainPropertyAnotation,
        core-shape:fhariterm-Property-fhariterm-hasDatatypePropertyDomainDatatype,
        core-shape:fhariterm-Property-fhariterm-hasDatatypePropertyRangeDatatype,
        core-shape:fhariterm-Property-fhariterm-hasObjectPropertyChain,
        core-shape:fhariterm-Property-fhariterm-hasObjectPropertyDomainClass,
        core-shape:fhariterm-Property-fhariterm-hasObjectPropertyInverseOf,
        core-shape:fhariterm-Property-fhariterm-hasObjectPropertyRangeClass,
        core-shape:fhariterm-Property-fhariterm-hasSubPropertyOf,
        core-shape:fhariterm-Property-fhariterm-isAssymetric,
        core-shape:fhariterm-Property-fhariterm-isFunctional,
        core-shape:fhariterm-Property-fhariterm-isInverseFunctional,
        core-shape:fhariterm-Property-fhariterm-isIrreflexive,
        core-shape:fhariterm-Property-fhariterm-isReflexive,
        core-shape:fhariterm-Property-fhariterm-isSymmetric,
        core-shape:fhariterm-Property-fhariterm-isTransitive ;
    sh:targetClass fhariterm:Property .

core-shape:fhariterm-Class-fhariterm-hasDisjointWith a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class fhariterm:Class ;
    sh:name "Has disjoint with" ;
    sh:path fhariterm:hasDisjointWith ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://hari-meta.org/ontology/fhariterm#hasDisjointWith> ?that . ?that <http://hari-meta.org/ontology/fhariterm#hasDisjointWith> ?this .}" ] .

