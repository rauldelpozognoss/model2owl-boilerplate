@prefix core-shape: <http://hari-meta.org/data-shape/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fhariexpression: <http://hari-meta.org/ontology/fhariexpression#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:fhariexpression-ExpressionShape a sh:NodeShape ;
    rdfs:label "Expression" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:fhariexpression-Expression-fhariexpression-hasCardinalityRestrictionValue,
        core-shape:fhariexpression-Expression-fhariexpression-hasCompositeExpression,
        core-shape:fhariexpression-Expression-fhariexpression-hasDescription,
        core-shape:fhariexpression-Expression-fhariexpression-hasTargetValue,
        core-shape:fhariexpression-Expression-fhariexpression-isSelf ;
    sh:targetClass fhariexpression:Expression .

core-shape:fhariexpression-Expression-fhariexpression-hasCardinalityRestrictionValue a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:integer ;
    sh:maxCount 1 ;
    sh:name "Has cardinality restriction value" ;
    sh:path fhariexpression:hasCardinalityRestrictionValue .

core-shape:fhariexpression-Expression-fhariexpression-hasCompositeExpression a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class fhariexpression:Expression ;
    sh:name "Has composite expression" ;
    sh:path fhariexpression:hasCompositeExpression ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://hari-meta.org/ontology/fhariexpression#hasCompositeExpression> ?that . ?that <http://hari-meta.org/ontology/fhariexpression#hasCompositeExpression> ?this .}" ] .

core-shape:fhariexpression-Expression-fhariexpression-hasDescription a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has description" ;
    sh:path fhariexpression:hasDescription .

core-shape:fhariexpression-Expression-fhariexpression-hasTargetValue a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:name "Has target value" ;
    sh:path fhariexpression:hasTargetValue .

core-shape:fhariexpression-Expression-fhariexpression-isSelf a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1 ;
    sh:name "Is self" ;
    sh:path fhariexpression:isSelf .

core-shape:core-shape a owl:Ontology ;
    rdfs:label "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:issued "2026-05-14"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Shapes"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from fhariexpression.xml on 2026-05-14" ;
    owl:imports fhariexpression:core,
        fhariexpression:core-restriction,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/data-shape/hari#core-shape-" ;
    owl:versionIRI core-shape:core-shape-1.0.0 ;
    owl:versionInfo "1.0.0" .

