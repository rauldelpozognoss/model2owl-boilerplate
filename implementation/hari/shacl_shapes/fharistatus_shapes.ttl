@prefix core-shape: <http://hari-meta.org/data-shape/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fharistatus: <http://hari-meta.org/ontology/fharistatus#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:fharistatus-DraftShape a sh:NodeShape ;
    rdfs:label "Draft" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass fharistatus:Draft .

core-shape:fharistatus-ObsoleteShape a sh:NodeShape ;
    rdfs:label "Obsolete" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass fharistatus:Obsolete .

core-shape:fharistatus-StableShape a sh:NodeShape ;
    rdfs:label "Stable" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass fharistatus:Stable .

core-shape:fharistatus-StatusTesaurusShape a sh:NodeShape ;
    rdfs:label "Status Tesaurus" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass fharistatus:StatusTesaurus .

core-shape:core-shape a owl:Ontology ;
    rdfs:label "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:issued "2026-05-14"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Shapes"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from fharistatus.xml on 2026-05-14" ;
    owl:imports fharistatus:core,
        fharistatus:core-restriction,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/data-shape/hari#core-shape-" ;
    owl:versionIRI core-shape:core-shape-1.0.0 ;
    owl:versionInfo "1.0.0" .

