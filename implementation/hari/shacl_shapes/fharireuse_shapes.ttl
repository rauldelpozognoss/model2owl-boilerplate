core-shape:fharireuse-DirectReuseDecisionShape a sh:NodeShape ;
    rdfs:label "Direct Reuse Decision" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:fharireuse-DirectReuseDecision-fharireuse-hasReuseReason ;
    sh:targetClass fharireuse:DirectReuseDecision .

core-shape:fharireuse-DirectReuseDecision-fharireuse-hasReuseReason a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:name "Has reuse reason" ;
    sh:path fharireuse:hasReuseReason .

