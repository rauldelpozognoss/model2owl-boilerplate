@prefix core-shape: <http://hari-meta.org/data-shape/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hariReuse: <http://hari-meta.org/ontology/hariReuse#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:hariReuse-ClassReuseShape a sh:NodeShape ;
    rdfs:label "Class Reuse" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hariReuse:ClassReuse .

core-shape:hariReuse-DatatypeReuseShape a sh:NodeShape ;
    rdfs:label "Datatype Reuse" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hariReuse:DatatypeReuse .

core-shape:hariReuse-DirectReuseDecisionShape a sh:NodeShape ;
    rdfs:label "Direct Reuse Decision" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hariReuse-DirectReuseDecision-hariReuse-hasReuseReason ;
    sh:sparql [ sh:select """SELECT ?this WHERE { ?this a <http://hari-meta.org/ontology/hariReuse#DirectReuseDecision> .
                }""" ] ;
    sh:targetClass hariReuse:DirectReuseDecision .

core-shape:hariReuse-PropertyReuseShape a sh:NodeShape ;
    rdfs:label "Property Reuse" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hariReuse:PropertyReuse .

core-shape:hariReuse-DirectReuseDecision-hariReuse-hasReuseReason a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:name "Has reuse reason" ;
    sh:path hariReuse:hasReuseReason .

core-shape:core-shape a owl:Ontology ;
    rdfs:label "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:issued "2026-05-12"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Shapes"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from hariReuse.xml on 2026-05-12" ;
    owl:imports hariReuse:core,
        hariReuse:core-restriction,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/data-shape/hari#core-shape-" ;
    owl:versionIRI core-shape:core-shape-1.0.0 ;
    owl:versionInfo "1.0.0" .

