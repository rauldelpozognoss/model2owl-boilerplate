@prefix core-shape: <http://hari-meta.org/data-shape/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:hariversion-OntologyVersionShape a sh:NodeShape ;
    rdfs:label "Ontology Version" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hariversion-OntologyVersion-hariversion-hasVersionIRI,
        core-shape:hariversion-OntologyVersion-hariversion-hasVersionInfo ;
    sh:targetClass <http://hari-meta.org/ontology/hariversion#OntologyVersion> .

core-shape:hariversion-OntologyVersion-hariversion-hasVersionIRI a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has version IRI" ;
    sh:path <http://hari-meta.org/ontology/hariversion#hasVersionIRI> .

core-shape:hariversion-OntologyVersion-hariversion-hasVersionInfo a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has version info" ;
    sh:path <http://hari-meta.org/ontology/hariversion#hasVersionInfo> .

core-shape:core-shape a owl:Ontology ;
    rdfs:label "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:issued "2026-05-13"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Shapes"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from hariVersion.xml on 2026-05-13" ;
    owl:imports <http://hari-meta.org/ontology/hariVersion#core>,
        <http://hari-meta.org/ontology/hariVersion#core-restriction>,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/data-shape/hari#core-shape-" ;
    owl:versionIRI core-shape:core-shape-1.0.0 ;
    owl:versionInfo "1.0.0" .

