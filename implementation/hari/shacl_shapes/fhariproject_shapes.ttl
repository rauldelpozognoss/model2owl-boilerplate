@prefix core-shape: <http://hari-meta.org/data-shape/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fhariproject: <http://hari-meta.org/ontology/fhariproject#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:fhariproject-OntologyProjectShape a sh:NodeShape ;
    rdfs:label "Ontology Project" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:fhariproject-OntologyProject-fhariproject-hasAcronym,
        core-shape:fhariproject-OntologyProject-fhariproject-hasDescription,
        core-shape:fhariproject-OntologyProject-fhariproject-hasOntologyIRI,
        core-shape:fhariproject-OntologyProject-fhariproject-hasOrganization,
        core-shape:fhariproject-OntologyProject-fhariproject-hasTitle ;
    sh:targetClass fhariproject:OntologyProject .

core-shape:fhariproject-OntologyProject-fhariproject-hasAcronym a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has acronym" ;
    sh:path fhariproject:hasAcronym .

core-shape:fhariproject-OntologyProject-fhariproject-hasDescription a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has description" ;
    sh:path fhariproject:hasDescription .

core-shape:fhariproject-OntologyProject-fhariproject-hasOntologyIRI a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has ontology IRI" ;
    sh:path fhariproject:hasOntologyIRI .

core-shape:fhariproject-OntologyProject-fhariproject-hasOrganization a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has organization" ;
    sh:path fhariproject:hasOrganization .

core-shape:fhariproject-OntologyProject-fhariproject-hasTitle a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has title" ;
    sh:path fhariproject:hasTitle .

core-shape:core-shape a owl:Ontology ;
    rdfs:label "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:issued "2026-05-14"^^xsd:date ;
