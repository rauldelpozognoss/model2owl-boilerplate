@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:hari_status-DraftShape a sh:NodeShape ;
    rdfs:label "Draft" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari_status-Draft-hari_status-hasInScheme ;
    sh:targetClass hari_status:Draft .

core-shape:hari_status-ObsoleteShape a sh:NodeShape ;
    rdfs:label "Obsolete" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari_status-Obsolete-hari_status-hasInScheme ;
    sh:targetClass hari_status:Obsolete .

core-shape:hari_status-StableShape a sh:NodeShape ;
    rdfs:label "Stable" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari_status-Stable-hari_status-hasInScheme ;
    sh:targetClass hari_status:Stable .

core-shape:hari_status-StatusShape a sh:NodeShape ;
    rdfs:label "Status" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:sparql [ sh:select """SELECT ?this WHERE { ?this a <http://hari-meta.org/ontology/hari_status#Status> .
                }""" ] ;
    sh:targetClass hari_status:Status .

core-shape:hari_status-ThingShape a sh:NodeShape ;
    rdfs:label "Thing" ;
    rdfs:comment "Clase raíz del metamodelo. Todas las clases diseñadas cuelgan de aquí." ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hari_status:Thing .

core-shape:hari_status-Draft-hari_status-hasInScheme a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class hari_status:Status ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has in scheme" ;
    sh:path hari_status:hasInScheme ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://hari-meta.org/ontology/hari_status#hasInScheme> ?that . ?that <http://hari-meta.org/ontology/hari_status#hasInScheme> ?this .}" ] .

core-shape:hari_status-Obsolete-hari_status-hasInScheme a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class hari_status:Status ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has in scheme" ;
    sh:path hari_status:hasInScheme ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://hari-meta.org/ontology/hari_status#hasInScheme> ?that . ?that <http://hari-meta.org/ontology/hari_status#hasInScheme> ?this .}" ] .

core-shape:hari_status-Stable-hari_status-hasInScheme a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class hari_status:Status ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has in scheme" ;
    sh:path hari_status:hasInScheme ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://hari-meta.org/ontology/hari_status#hasInScheme> ?that . ?that <http://hari-meta.org/ontology/hari_status#hasInScheme> ?this .}" ] .

