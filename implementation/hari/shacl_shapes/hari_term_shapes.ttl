core-shape:hari_term-AllValuesFromShape a sh:NodeShape ;
    rdfs:label "All Values From" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hari_term:AllValuesFrom .

core-shape:hari_term-AnotationPropertyShape a sh:NodeShape ;
    rdfs:label "Anotation Property" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari_term-AnotationProperty-hari_term-hasDomainAnotation ;
    sh:targetClass hari_term:AnotationProperty .

core-shape:hari_term-CardinalityRestrictionShape a sh:NodeShape ;
