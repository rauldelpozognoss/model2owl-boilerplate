        core-shape:hari_term-CardinalityRestriction-hari_term-hasQualifiedTarget ;
    sh:sparql [ sh:select """SELECT ?this WHERE { ?this a <http://hari-meta.org/ontology/hari_term#CardinalityRestriction> .
                }""" ] ;
    sh:targetClass hari_term:CardinalityRestriction .

