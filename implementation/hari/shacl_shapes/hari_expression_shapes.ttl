    sh:targetClass <http://hari-meta.org/ontology/hari_expression#Union> .

core-shape:hari_expression-ValuesFromShape a sh:NodeShape ;
    rdfs:label "Values From" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:sparql [ sh:select """SELECT ?this WHERE { ?this a <http://hari-meta.org/ontology/hari_expression#ValuesFrom> .
                }""" ] ;
    sh:targetClass <http://hari-meta.org/ontology/hari_expression#ValuesFrom> .

core-shape:hari_expression-CardinalityRestriction-hari_expression-hasCardinalityValue a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:integer ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has cardinality value" ;
    sh:path <http://hari-meta.org/ontology/hari_expression#hasCardinalityValue> .

core-shape:hari_expression-Expression-hari_expression-hasCompositeExpression a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class <http://hari-meta.org/ontology/hari_expression#Expression> ;
    sh:name "Has composite expression" ;
    sh:path <http://hari-meta.org/ontology/hari_expression#hasCompositeExpression> ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://hari-meta.org/ontology/hari_expression#hasCompositeExpression> ?that . ?that <http://hari-meta.org/ontology/hari_expression#hasCompositeExpression> ?this .}" ] .

core-shape:hari_expression-Expression-hari_expression-hasDescription a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has description" ;
    sh:path <http://hari-meta.org/ontology/hari_expression#hasDescription> .

core-shape:hari_expression-HasSelf-hari_expression-isSelf a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Is self" ;
    sh:path <http://hari-meta.org/ontology/hari_expression#isSelf> .

core-shape:hari_expression-HasValue-hari_expression-hasTargetValue a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has target value" ;
    sh:path <http://hari-meta.org/ontology/hari_expression#hasTargetValue> .

