@prefix core-shape: <http://hari-meta.org/data-shape/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hariproject: <http://hari-meta.org/ontology/hariproject#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:hariproject-OntologyProjectShape a sh:NodeShape ;
    rdfs:label "Ontology Project" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hariproject-OntologyProject-hariproject-hasAcronym,
        core-shape:hariproject-OntologyProject-hariproject-hasDescription,
        core-shape:hariproject-OntologyProject-hariproject-hasOntologyIRI,
        core-shape:hariproject-OntologyProject-hariproject-hasOrganization,
        core-shape:hariproject-OntologyProject-hariproject-hasTitle ;
    sh:targetClass hariproject:OntologyProject .

core-shape:hariproject-OntologyProject-hariproject-hasAcronym a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has acronym" ;
    sh:path hariproject:hasAcronym .

core-shape:hariproject-OntologyProject-hariproject-hasDescription a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has description" ;
    sh:path hariproject:hasDescription .

core-shape:hariproject-OntologyProject-hariproject-hasOntologyIRI a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has ontology IRI" ;
    sh:path hariproject:hasOntologyIRI .

core-shape:hariproject-OntologyProject-hariproject-hasOrganization a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has organization" ;
    sh:path hariproject:hasOrganization .

core-shape:hariproject-OntologyProject-hariproject-hasTitle a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has title" ;
    sh:path hariproject:hasTitle .

core-shape:core-shape a owl:Ontology ;
    rdfs:label "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:issued "2026-05-13"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Shapes"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from hariProject.xml on 2026-05-13" ;
    owl:imports <http://hari-meta.org/ontology/hariProject#core>,
        <http://hari-meta.org/ontology/hariProject#core-restriction>,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/data-shape/hari#core-shape-" ;
    owl:versionIRI core-shape:core-shape-1.0.0 ;
    owl:versionInfo "1.0.0" .

