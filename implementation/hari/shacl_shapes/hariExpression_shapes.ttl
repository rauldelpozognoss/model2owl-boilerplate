@prefix core-shape: <http://hari-meta.org/data-shape/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:hariexpression-ExpressionShape a sh:NodeShape ;
    rdfs:label "Expression" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hariexpression-Expression-hariexpression-hasCardinalityRestrictionValue,
        core-shape:hariexpression-Expression-hariexpression-hasCompositeExpression,
        core-shape:hariexpression-Expression-hariexpression-hasDescripcion,
        core-shape:hariexpression-Expression-hariexpression-hasTargetValue,
        core-shape:hariexpression-Expression-hariexpression-isSelf ;
    sh:targetClass <http://hari-meta.org/ontology/hariexpression#Expression> .

core-shape:hariexpression-Expression-hariexpression-hasCardinalityRestrictionValue a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:integer ;
    sh:maxCount 1 ;
    sh:name "Has cardinality restriction value" ;
    sh:path <http://hari-meta.org/ontology/hariexpression#hasCardinalityRestrictionValue> .

core-shape:hariexpression-Expression-hariexpression-hasCompositeExpression a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class <http://hari-meta.org/ontology/hariexpression#Expression> ;
    sh:name "Has composite expression" ;
    sh:path <http://hari-meta.org/ontology/hariexpression#hasCompositeExpression> ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://hari-meta.org/ontology/hariexpression#hasCompositeExpression> ?that . ?that <http://hari-meta.org/ontology/hariexpression#hasCompositeExpression> ?this .}" ] .

core-shape:hariexpression-Expression-hariexpression-hasDescripcion a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has descripcion" ;
    sh:path <http://hari-meta.org/ontology/hariexpression#hasDescripcion> .

core-shape:hariexpression-Expression-hariexpression-hasTargetValue a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:name "Has target value" ;
    sh:path <http://hari-meta.org/ontology/hariexpression#hasTargetValue> .

core-shape:hariexpression-Expression-hariexpression-isSelf a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1 ;
    sh:name "Is self" ;
    sh:path <http://hari-meta.org/ontology/hariexpression#isSelf> .

core-shape:core-shape a owl:Ontology ;
    rdfs:label "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:issued "2026-05-13"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Shapes"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from hariExpression.xml on 2026-05-13" ;
    owl:imports <http://hari-meta.org/ontology/hariExpression#core>,
        <http://hari-meta.org/ontology/hariExpression#core-restriction>,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/data-shape/hari#core-shape-" ;
    owl:versionIRI core-shape:core-shape-1.0.0 ;
    owl:versionInfo "1.0.0" .

