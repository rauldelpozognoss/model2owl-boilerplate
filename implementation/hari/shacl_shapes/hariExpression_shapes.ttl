    dcterms:title "Ontología Hari Shapes"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from hariExpression.xml on 2026-05-12" ;
    owl:imports hariExpression:core,
        hariExpression:core-restriction,
        skos: ;
    owl:incompatibleWith "" ;
