@prefix core-shape: <http://hari-meta.org/data-shape/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix haristatus: <http://hari-meta.org/ontology/haristatus#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:haristatus-DraftShape a sh:NodeShape ;
    rdfs:label "Draft" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:haristatus-Draft-haristatus-hasInScheme ;
    sh:targetClass haristatus:Draft .

core-shape:haristatus-ObsoleteShape a sh:NodeShape ;
    rdfs:label "Obsolete" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:haristatus-Obsolete-haristatus-hasInScheme ;
    sh:targetClass haristatus:Obsolete .

core-shape:haristatus-StableShape a sh:NodeShape ;
    rdfs:label "Stable" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:haristatus-Stable-haristatus-hasInScheme ;
    sh:targetClass haristatus:Stable .

core-shape:haristatus-StatusShape a sh:NodeShape ;
    rdfs:label "Status" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:sparql [ sh:select """SELECT ?this WHERE { ?this a <http://hari-meta.org/ontology/haristatus#Status> .
                }""" ] ;
    sh:targetClass haristatus:Status .

core-shape:haristatus-Draft-haristatus-hasInScheme a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class haristatus:Status ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has in scheme" ;
    sh:path haristatus:hasInScheme ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://hari-meta.org/ontology/haristatus#hasInScheme> ?that . ?that <http://hari-meta.org/ontology/haristatus#hasInScheme> ?this .}" ] .

core-shape:haristatus-Obsolete-haristatus-hasInScheme a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class haristatus:Status ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has in scheme" ;
    sh:path haristatus:hasInScheme ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://hari-meta.org/ontology/haristatus#hasInScheme> ?that . ?that <http://hari-meta.org/ontology/haristatus#hasInScheme> ?this .}" ] .

core-shape:haristatus-Stable-haristatus-hasInScheme a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class haristatus:Status ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has in scheme" ;
    sh:path haristatus:hasInScheme ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://hari-meta.org/ontology/haristatus#hasInScheme> ?that . ?that <http://hari-meta.org/ontology/haristatus#hasInScheme> ?this .}" ] .

core-shape:core-shape a owl:Ontology ;
    rdfs:label "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:issued "2026-05-12"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Shapes"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from hariStatus.xml on 2026-05-12" ;
    owl:imports <http://hari-meta.org/ontology/hariStatus#core>,
        <http://hari-meta.org/ontology/hariStatus#core-restriction>,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/data-shape/hari#core-shape-" ;
    owl:versionIRI core-shape:core-shape-1.0.0 ;
    owl:versionInfo "1.0.0" .

