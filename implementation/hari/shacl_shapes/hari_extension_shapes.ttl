@prefix core-shape: <http://hari-meta.org/data-shape/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hari_extension: <http://hari-meta.org/ontology/hari_extension#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:hari_extension-ConstraintExtensionShape a sh:NodeShape ;
    rdfs:label "Constraint Extension" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hari_extension:ConstraintExtension .

core-shape:hari_extension-ExtensionDecisionShape a sh:NodeShape ;
    rdfs:label "Extension Decision" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari_extension-ExtensionDecision-hari_extension-hasJustificacion ;
    sh:sparql [ sh:select """SELECT ?this WHERE { ?this a <http://hari-meta.org/ontology/hari_extension#ExtensionDecision> .
                }""" ] ;
    sh:targetClass hari_extension:ExtensionDecision .

core-shape:hari_extension-PropertyExtensionShape a sh:NodeShape ;
    rdfs:label "Property Extension" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hari_extension:PropertyExtension .

core-shape:hari_extension-SemanticExtensionShape a sh:NodeShape ;
    rdfs:label "Semantic Extension" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hari_extension:SemanticExtension .

core-shape:hari_extension-ThingShape a sh:NodeShape ;
    rdfs:label "Thing" ;
    rdfs:comment "Clase raíz del metamodelo. Todas las clases diseñadas cuelgan de aquí." ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hari_extension:Thing .

core-shape:hari_extension-ExtensionDecision-hari_extension-hasJustificacion a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:name "Has justificacion" ;
    sh:path hari_extension:hasJustificacion .

core-shape:core-shape a owl:Ontology ;
    rdfs:label "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Shapes SHACL para validación de la ontología Hari."@en ;
    dcterms:issued "2026-04-22"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Shapes"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from hari_extension.xml on 2026-04-22" ;
    owl:imports hari_extension:core,
        hari_extension:core-restriction,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/data-shape/hari#core-shape-" ;
    owl:versionIRI core-shape:core-shape-1.0.0 ;
    owl:versionInfo "1.0.0" .

