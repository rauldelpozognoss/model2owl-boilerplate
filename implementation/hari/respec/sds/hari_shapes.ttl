@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:hari-AllValuesFromShape a sh:NodeShape ;
    rdfs:label "All Values From" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hari:AllValuesFrom .

core-shape:hari-AnotationPropertyShape a sh:NodeShape ;
    rdfs:label "Anotation Property" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari-AnotationProperty-hari-hasDomainAnotation ;
    sh:targetClass hari:AnotationProperty .

core-shape:hari-ApplicationShape a sh:NodeShape ;
    rdfs:label "Application" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari-Application-hari-hasInScheme ;
    sh:targetClass hari:Application .

core-shape:hari-CardinalityRestrictionShape a sh:NodeShape ;
    rdfs:label "Cardinality Restriction" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari-CardinalityRestriction-hari-hasCardinalityValue,
        core-shape:hari-CardinalityRestriction-hari-hasQualifiedTarget ;
    sh:sparql [ sh:select """SELECT ?this WHERE { ?this a <http://hari-meta.org/ontology/hari#CardinalityRestriction> .
                }""" ] ;
    sh:targetClass hari:CardinalityRestriction .

