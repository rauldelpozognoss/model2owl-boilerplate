core-shape:hari-DirectReuseDecisionShape a sh:NodeShape ;
    rdfs:label "Direct Reuse Decision" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari-DirectReuseDecision-hari-hasReason ;
    sh:sparql [ sh:select """SELECT ?this WHERE { ?this a <http://hari-meta.org/ontology/hari#DirectReuseDecision> .
                }""" ] ;
    sh:targetClass hari:DirectReuseDecision .

core-shape:hari-ExtensionDecisionShape a sh:NodeShape ;
