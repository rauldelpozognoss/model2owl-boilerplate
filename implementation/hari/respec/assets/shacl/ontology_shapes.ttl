    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari-ClassReuse-hari-hasReusedClassIRI ;
    sh:targetClass hari:ClassReuse .

core-shape:hari-ClassShape a sh:NodeShape ;
    rdfs:label "Class" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari-Class-hari-hasDisjointWith,
        core-shape:hari-Class-hari-hasEquivalenteTo,
        core-shape:hari-Class-hari-hasRestriction,
        core-shape:hari-Class-hari-hasSubClassOf ;
    sh:targetClass hari:Class .

core-shape:hari-DatatypePropertyShape a sh:NodeShape ;
