core-shape:hari-AnotationPropertyShape a sh:NodeShape ;
    rdfs:label "Anotation Property" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass hari:AnotationProperty .

core-shape:hari-AttributeExtensionShape a sh:NodeShape ;
    rdfs:label "Attribute Extension" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari-AttributeExtension-hari-hasAddedPropertyIRI ;
    sh:targetClass hari:AttributeExtension .

core-shape:hari-CardinalityExtensionShape a sh:NodeShape ;
    rdfs:label "Cardinality Extension" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:hari-CardinalityExtension-hari-hasCardinalityChangedIRI ;
    sh:targetClass hari:CardinalityExtension .

core-shape:hari-ClassReuseShape a sh:NodeShape ;
