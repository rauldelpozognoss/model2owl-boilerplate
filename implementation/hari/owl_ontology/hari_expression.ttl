@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hari_expression:AllValuesFrom a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf hari_expression:ValuesFrom ;
    skos:prefLabel "All Values From"@en .

hari_expression:Complement a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf hari_expression:LogicalOperation ;
    skos:prefLabel "Complement"@en .

hari_expression:ExactCardinality a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf hari_expression:CardinalityRestriction ;
    skos:prefLabel "Exact Cardinality"@en .

hari_expression:HasSelf a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf hari_expression:Restriction ;
    skos:prefLabel "Has Self"@en .

hari_expression:HasValue a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf hari_expression:Restriction ;
    skos:prefLabel "Has Value"@en .

hari_expression:Intersection a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf hari_expression:LogicalOperation ;
    skos:prefLabel "Intersection"@en .

hari_expression:MaxCardinality a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf hari_expression:CardinalityRestriction ;
    skos:prefLabel "Max Cardinality"@en .

hari_expression:MinCardinality a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf hari_expression:CardinalityRestriction ;
    skos:prefLabel "Min Cardinality"@en .

hari_expression:SomeValuesFrom a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf hari_expression:ValuesFrom ;
    skos:prefLabel "Some Values From"@en .

hari_expression:Union a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf hari_expression:LogicalOperation ;
    skos:prefLabel "Union"@en .

hari_expression:hasCardinalityValue a owl:DatatypeProperty ;
    rdfs:isDefinedBy hari_expression:core ;
    skos:prefLabel "has Cardinality Value"@en .

hari_expression:hasCompositeExpression a owl:ObjectProperty ;
    rdfs:isDefinedBy hari_expression:core ;
    skos:prefLabel "has Composite Expression"@en .

hari_expression:hasTargetValue a owl:DatatypeProperty ;
    rdfs:isDefinedBy hari_expression:core ;
    skos:prefLabel "has Target Value"@en .

hari_expression:isSelf a owl:DatatypeProperty ;
    rdfs:isDefinedBy hari_expression:core ;
    skos:prefLabel "is Self"@en .

hari_expression:Expression a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf owl:Thing ;
    skos:prefLabel "Expression"@en .

hari_expression:ValuesFrom a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf hari_expression:Restriction ;
    skos:prefLabel "Values From"@en .

hari_expression:CardinalityRestriction a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf hari_expression:Restriction ;
    skos:prefLabel "Cardinality Restriction"@en .

hari_expression:LogicalOperation a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf hari_expression:Expression ;
    skos:prefLabel "Logical Operation"@en .

hari_expression:Restriction a owl:Class ;
    rdfs:isDefinedBy hari_expression:core ;
    rdfs:subClassOf hari_expression:Expression ;
    skos:prefLabel "Restriction"@en .

hari_expression:core a owl:Ontology ;
    rdfs:label "Ontología principal del proyecto Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
