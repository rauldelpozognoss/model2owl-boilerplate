@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hariextension: <http://hari-meta.org/ontology/hariextension#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://hari-meta.org/ontology/hariExtension#core-restriction> a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-05-12"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hariExtension.xml on 
                2026-05-12""" ;
    owl:imports <http://hari-meta.org/ontology/hariExtension#core>,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hariExtension#core-restriction-" ;
    owl:versionIRI <http://hari-meta.org/ontology/hariExtension#core-restriction-1.0.0> ;
    owl:versionInfo "1.0.0" .

hariextension:ExtensionDecision rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality 1 ;
            owl:onDataRange xsd:string ;
            owl:onProperty hariextension:hasExtensionReason ] .

hariextension:hasExtensionReason rdfs:domain hariextension:ExtensionDecision ;
    rdfs:range xsd:string .

