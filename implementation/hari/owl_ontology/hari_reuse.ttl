@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hari_reuse: <http://hari-meta.org/ontology/hari_reuse#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hari_reuse:ClassReuse a owl:Class ;
    rdfs:isDefinedBy hari_reuse:core ;
    rdfs:subClassOf hari_reuse:DirectReuseDecision ;
    skos:prefLabel "Class Reuse"@en .

hari_reuse:PropertyReuse a owl:Class ;
    rdfs:isDefinedBy hari_reuse:core ;
    rdfs:subClassOf hari_reuse:DirectReuseDecision ;
    skos:prefLabel "Property Reuse"@en .

hari_reuse:hasReason a owl:DatatypeProperty ;
    rdfs:isDefinedBy hari_reuse:core ;
    skos:prefLabel "has Reason"@en .

hari_reuse:Thing a owl:Class ;
    rdfs:isDefinedBy hari_reuse:core ;
    skos:definition "Clase raíz del metamodelo. Todas las clases diseñadas cuelgan de aquí."@en ;
    skos:prefLabel "Thing"@en .

hari_reuse:DirectReuseDecision a owl:Class ;
    rdfs:isDefinedBy hari_reuse:core ;
    rdfs:subClassOf hari_reuse:Thing ;
    skos:prefLabel "Direct Reuse Decision"@en .

hari_reuse:core a owl:Ontology ;
    rdfs:label "Ontología principal del proyecto Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Ontología principal del proyecto Hari."@en ;
    dcterms:issued "2026-04-22"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Core"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from hari_reuse.xml on 2026-04-22" ;
    owl:imports skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari_reuse#core-" ;
    owl:versionIRI hari_reuse:core-1.0.0 ;
    owl:versionInfo "1.0.0" .

