@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hari_project: <http://hari-meta.org/ontology/hari_project#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hari_project:OntologyProject a owl:Class ;
    rdfs:isDefinedBy hari_project:core ;
    rdfs:subClassOf hari_project:Thing ;
    skos:prefLabel "Ontology Project"@en .

hari_project:hasAcronym a owl:DatatypeProperty ;
    rdfs:isDefinedBy hari_project:core ;
    skos:prefLabel "has Acronym"@en .

hari_project:hasDescription a owl:DatatypeProperty ;
    rdfs:isDefinedBy hari_project:core ;
    skos:prefLabel "has Description"@en .

hari_project:hasOntologyIRI a owl:DatatypeProperty ;
    rdfs:isDefinedBy hari_project:core ;
    skos:prefLabel "has Ontology IRI"@en .

hari_project:hasOrganization a owl:DatatypeProperty ;
    rdfs:isDefinedBy hari_project:core ;
    skos:prefLabel "has Organization"@en .

hari_project:hasTitle a owl:DatatypeProperty ;
    rdfs:isDefinedBy hari_project:core ;
    skos:prefLabel "has Title"@en .

hari_project:Thing a owl:Class ;
    rdfs:isDefinedBy hari_project:core ;
    skos:definition "Clase raíz del metamodelo. Todas las clases diseñadas cuelgan de aquí."@en ;
    skos:prefLabel "Thing"@en .

hari_project:core a owl:Ontology ;
    rdfs:label "Ontología principal del proyecto Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Ontología principal del proyecto Hari."@en ;
    dcterms:issued "2026-04-20"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Core"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from hari_project.xml on 2026-04-20" ;
    owl:imports skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari_project#core-" ;
    owl:versionIRI hari_project:core-1.0.0 ;
    owl:versionInfo "1.0.0" .

