hariExpression:AllValuesFrom a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf hariExpression:ValuesFrom ;
    skos:prefLabel "All Values From"@en .

hariExpression:Complement a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf hariExpression:LogicalOperation ;
    skos:prefLabel "Complement"@en .

hariExpression:ExactCardinality a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf hariExpression:CardinalityRestriction ;
    skos:prefLabel "Exact Cardinality"@en .

hariExpression:HasSelf a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf hariExpression:Restriction ;
    skos:prefLabel "Has Self"@en .

hariExpression:HasValue a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf hariExpression:Restriction ;
    skos:prefLabel "Has Value"@en .

hariExpression:Intersection a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf hariExpression:LogicalOperation ;
    skos:prefLabel "Intersection"@en .

hariExpression:MaxCardinality a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf hariExpression:CardinalityRestriction ;
    skos:prefLabel "Max Cardinality"@en .

hariExpression:MinCardinality a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf hariExpression:CardinalityRestriction ;
    skos:prefLabel "Min Cardinality"@en .

hariExpression:SomeValuesFrom a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf hariExpression:ValuesFrom ;
    skos:prefLabel "Some Values From"@en .

hariExpression:Union a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf hariExpression:LogicalOperation ;
    skos:prefLabel "Union"@en .

hariExpression:hasCardinalityValue a owl:DatatypeProperty ;
    rdfs:isDefinedBy hariExpression:core ;
    skos:prefLabel "has Cardinality Value"@en .

hariExpression:hasCompositeExpression a owl:ObjectProperty ;
    rdfs:isDefinedBy hariExpression:core ;
    skos:prefLabel "has Composite Expression"@en .

hariExpression:hasDescripcion a owl:DatatypeProperty ;
    rdfs:isDefinedBy hariExpression:core ;
    skos:prefLabel "has Descripcion"@en .

hariExpression:hasTargetValue a owl:DatatypeProperty ;
    rdfs:isDefinedBy hariExpression:core ;
    skos:prefLabel "has Target Value"@en .

hariExpression:isSelf a owl:DatatypeProperty ;
    rdfs:isDefinedBy hariExpression:core ;
    skos:prefLabel "is Self"@en .

hariExpression:Expression a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf owl:Thing ;
    skos:prefLabel "Expression"@en .

hariExpression:ValuesFrom a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf hariExpression:Restriction ;
    skos:prefLabel "Values From"@en .

hariExpression:CardinalityRestriction a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf hariExpression:Restriction ;
    skos:prefLabel "Cardinality Restriction"@en .

hariExpression:LogicalOperation a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf hariExpression:Expression ;
    skos:prefLabel "Logical Operation"@en .

hariExpression:Restriction a owl:Class ;
    rdfs:isDefinedBy hariExpression:core ;
    rdfs:subClassOf hariExpression:Expression ;
    skos:prefLabel "Restriction"@en .

