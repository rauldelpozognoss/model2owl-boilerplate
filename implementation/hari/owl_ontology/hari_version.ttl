@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hari: <http://hari-meta.org/ontology/hari#> .
@prefix hari_version: <http://hari-meta.org/ontology/hari_version#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hari_version:OntologyVersion a owl:Class ;
    rdfs:isDefinedBy hari:core ;
    rdfs:subClassOf hari_version:Thing ;
    skos:prefLabel "Ontology Version"@en .

hari_version:hasKnowledgeDomain a owl:DatatypeProperty ;
    rdfs:isDefinedBy hari:core ;
    skos:prefLabel "has Knowledge Domain"@en .

hari_version:hasPriorVersionIRI a owl:DatatypeProperty ;
    rdfs:isDefinedBy hari:core ;
    skos:prefLabel "has Prior Version IRI"@en .

hari_version:hasVersionIRI a owl:DatatypeProperty ;
    rdfs:isDefinedBy hari:core ;
    skos:prefLabel "has Version IRI"@en .

hari_version:hasVersionInfo a owl:DatatypeProperty ;
    rdfs:isDefinedBy hari:core ;
    skos:prefLabel "has Version Info"@en .

hari_version:Thing a owl:Class ;
    rdfs:isDefinedBy hari:core ;
    skos:definition "Clase raíz del metamodelo. Todas las clases diseñadas cuelgan de aquí."@en ;
    skos:prefLabel "Thing"@en .

hari:core a owl:Ontology ;
    rdfs:label "Ontología principal del proyecto Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Ontología principal del proyecto Hari."@en ;
    dcterms:issued "2026-04-15"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Core"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from hari_version.xml on 2026-04-15" ;
    owl:imports skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari#core-" ;
    owl:versionIRI hari:core-1.0.0 ;
    owl:versionInfo "1.0.0" .

