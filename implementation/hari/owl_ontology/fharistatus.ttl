fharistatus:Draft a owl:Class ;
    rdfs:isDefinedBy fharistatus:core ;
    rdfs:subClassOf fharistatus:StatusTesaurus ;
    skos:prefLabel "Draft"@en .

fharistatus:Obsolete a owl:Class ;
    rdfs:isDefinedBy fharistatus:core ;
    rdfs:subClassOf fharistatus:StatusTesaurus ;
    skos:prefLabel "Obsolete"@en .

fharistatus:Stable a owl:Class ;
    rdfs:isDefinedBy fharistatus:core ;
    rdfs:subClassOf fharistatus:StatusTesaurus ;
    skos:prefLabel "Stable"@en .

fharistatus:StatusTesaurus a owl:Class ;
    rdfs:isDefinedBy fharistatus:core ;
    rdfs:subClassOf owl:Thing ;
    skos:prefLabel "Status Tesaurus"@en .

fharistatus:core a owl:Ontology ;
    rdfs:label "Ontología principal del proyecto Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
