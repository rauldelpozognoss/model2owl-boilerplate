:AllValuesFrom a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf :ValuesFrom ;
    skos:prefLabel "All Values From"@en .

:Complement a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf :LogicalOperation ;
    skos:prefLabel "Complement"@en .

:ExactCardinality a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf :CardinalityRestriction ;
    skos:prefLabel "Exact Cardinality"@en .

:HasSelf a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf :Restriction ;
    skos:prefLabel "Has Self"@en .

:HasValue a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf :Restriction ;
    skos:prefLabel "Has Value"@en .

:Intersection a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf :LogicalOperation ;
    skos:prefLabel "Intersection"@en .

:MaxCardinality a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf :CardinalityRestriction ;
    skos:prefLabel "Max Cardinality"@en .

:MinCardinality a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf :CardinalityRestriction ;
    skos:prefLabel "Min Cardinality"@en .

:SomeValuesFrom a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf :ValuesFrom ;
    skos:prefLabel "Some Values From"@en .

:Union a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf :LogicalOperation ;
    skos:prefLabel "Union"@en .

:ExpressionTypeTesaurus a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf owl:Thing ;
    skos:prefLabel "Expression Type Tesaurus"@en .

:ValuesFrom a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf :Restriction ;
    skos:prefLabel "Values From"@en .

:CardinalityRestriction a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf :Restriction ;
    skos:prefLabel "Cardinality Restriction"@en .

:LogicalOperation a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf :ExpressionTypeTesaurus ;
    skos:prefLabel "Logical Operation"@en .

:Restriction a owl:Class ;
    rdfs:isDefinedBy :core ;
    rdfs:subClassOf :ExpressionTypeTesaurus ;
    skos:prefLabel "Restriction"@en .

:core a owl:Ontology ;
    rdfs:label "Ontología principal del proyecto Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Ontología principal del proyecto Hari."@en ;
