@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hariReuse: <http://hari-meta.org/ontology/hariReuse#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hariReuse:core-restriction a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-05-12"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hariReuse.xml on 
                2026-05-12""" ;
    owl:imports hariReuse:core,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hariReuse#core-restriction-" ;
    owl:versionIRI hariReuse:core-restriction-1.0.0 ;
    owl:versionInfo "1.0.0" .

hariReuse:DirectReuseDecision rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality 1 ;
            owl:onDataRange xsd:string ;
            owl:onProperty hariReuse:hasReuseReason ] .

hariReuse:hasReuseReason rdfs:domain hariReuse:DirectReuseDecision ;
    rdfs:range xsd:string .

