fharilevel:Application a owl:Class ;
    rdfs:isDefinedBy fharilevel:core ;
    rdfs:subClassOf fharilevel:LevelTesaurus ;
    skos:prefLabel "Application"@en .

fharilevel:Core a owl:Class ;
    rdfs:isDefinedBy fharilevel:core ;
    rdfs:subClassOf fharilevel:LevelTesaurus ;
    skos:prefLabel "Core"@en .

fharilevel:Domain a owl:Class ;
    rdfs:isDefinedBy fharilevel:core ;
    rdfs:subClassOf fharilevel:LevelTesaurus ;
    skos:prefLabel "Domain"@en .

fharilevel:Foundational a owl:Class ;
    rdfs:isDefinedBy fharilevel:core ;
    rdfs:subClassOf fharilevel:LevelTesaurus ;
    skos:prefLabel "Foundational"@en .

fharilevel:LevelTesaurus a owl:Class ;
    rdfs:isDefinedBy fharilevel:core ;
    rdfs:subClassOf owl:Thing ;
    skos:prefLabel "Level Tesaurus"@en .

