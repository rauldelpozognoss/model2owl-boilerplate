@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hariStatus: <http://hari-meta.org/ontology/hariStatus#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hariStatus:core-restriction a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-05-12"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hariStatus.xml on 
                2026-05-12""" ;
    owl:imports hariStatus:core,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hariStatus#core-restriction-" ;
    owl:versionIRI hariStatus:core-restriction-1.0.0 ;
    owl:versionInfo "1.0.0" .

hariStatus:Draft rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hariStatus:Status ;
            owl:onProperty hariStatus:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

hariStatus:Obsolete rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hariStatus:Status ;
            owl:onProperty hariStatus:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

hariStatus:Stable rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hariStatus:Status ;
            owl:onProperty hariStatus:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

hariStatus:hasInScheme a owl:FunctionalProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hariStatus:Draft hariStatus:Stable hariStatus:Obsolete ) ] ;
    rdfs:range hariStatus:Status .

