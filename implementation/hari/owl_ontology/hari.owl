    <!-- http://hari-meta.org/ontology/hari#hasInScheme -->

    <owl:ObjectProperty rdf:about="http://hari-meta.org/ontology/hari#hasInScheme">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://hari-meta.org/ontology/hari#Application"/>
                    <rdf:Description rdf:about="http://hari-meta.org/ontology/hari#Core"/>
                    <rdf:Description rdf:about="http://hari-meta.org/ontology/hari#Domain"/>
                    <rdf:Description rdf:about="http://hari-meta.org/ontology/hari#Draft"/>
                    <rdf:Description rdf:about="http://hari-meta.org/ontology/hari#Foundational"/>
                    <rdf:Description rdf:about="http://hari-meta.org/ontology/hari#Obsolete"/>
                    <rdf:Description rdf:about="http://hari-meta.org/ontology/hari#Stable"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://hari-meta.org/ontology/hari#Level"/>
                    <rdf:Description rdf:about="http://hari-meta.org/ontology/hari#Status"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:isDefinedBy rdf:resource="http://hari-meta.org/ontology/hari#core"/>
        <skos:prefLabel xml:lang="en">has In Scheme</skos:prefLabel>
    </owl:ObjectProperty>
    


