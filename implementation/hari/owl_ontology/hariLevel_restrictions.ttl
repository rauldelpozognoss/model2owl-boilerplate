@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hariLevel: <http://hari-meta.org/ontology/hariLevel#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hariLevel:core-restriction a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-05-12"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hariLevel.xml on 
                2026-05-12""" ;
    owl:imports hariLevel:core,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hariLevel#core-restriction-" ;
    owl:versionIRI hariLevel:core-restriction-1.0.0 ;
    owl:versionInfo "1.0.0" .

hariLevel:Application rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hariLevel:Level ;
            owl:onProperty hariLevel:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

hariLevel:Core rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hariLevel:Level ;
            owl:onProperty hariLevel:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

hariLevel:Domain rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hariLevel:Level ;
            owl:onProperty hariLevel:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

hariLevel:Foundational rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hariLevel:Level ;
            owl:onProperty hariLevel:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

hariLevel:hasInScheme a owl:FunctionalProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hariLevel:Foundational hariLevel:Core hariLevel:Domain hariLevel:Application ) ] ;
    rdfs:range hariLevel:Level .

