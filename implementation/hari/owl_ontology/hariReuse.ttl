hariReuse:ClassReuse a owl:Class ;
    rdfs:isDefinedBy hariReuse:core ;
    rdfs:subClassOf hariReuse:DirectReuseDecision ;
    skos:prefLabel "Class Reuse"@en .

hariReuse:DatatypeReuse a owl:Class ;
    rdfs:isDefinedBy hariReuse:core ;
    rdfs:subClassOf hariReuse:DirectReuseDecision ;
    skos:prefLabel "Datatype Reuse"@en .

hariReuse:PropertyReuse a owl:Class ;
    rdfs:isDefinedBy hariReuse:core ;
    rdfs:subClassOf hariReuse:DirectReuseDecision ;
    skos:prefLabel "Property Reuse"@en .

hariReuse:hasReuseReason a owl:DatatypeProperty ;
    rdfs:isDefinedBy hariReuse:core ;
    skos:prefLabel "has Reuse Reason"@en .

hariReuse:DirectReuseDecision a owl:Class ;
    rdfs:isDefinedBy hariReuse:core ;
    rdfs:subClassOf owl:Thing ;
    skos:prefLabel "Direct Reuse Decision"@en .

hariReuse:core a owl:Ontology ;
    rdfs:label "Ontología principal del proyecto Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Ontología principal del proyecto Hari."@en ;
