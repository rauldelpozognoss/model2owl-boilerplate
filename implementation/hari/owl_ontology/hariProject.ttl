hariProject:OntologyProject a owl:Class ;
    rdfs:isDefinedBy hariProject:core ;
    rdfs:subClassOf owl:Thing ;
    skos:prefLabel "Ontology Project"@en .

hariProject:hasAcronym a owl:DatatypeProperty ;
    rdfs:isDefinedBy hariProject:core ;
    skos:prefLabel "has Acronym"@en .

hariProject:hasDescription a owl:DatatypeProperty ;
    rdfs:isDefinedBy hariProject:core ;
    skos:prefLabel "has Description"@en .

hariProject:hasOntologyIRI a owl:DatatypeProperty ;
    rdfs:isDefinedBy hariProject:core ;
    skos:prefLabel "has Ontology IRI"@en .

hariProject:hasOrganization a owl:DatatypeProperty ;
    rdfs:isDefinedBy hariProject:core ;
    skos:prefLabel "has Organization"@en .

hariProject:hasTitle a owl:DatatypeProperty ;
    rdfs:isDefinedBy hariProject:core ;
    skos:prefLabel "has Title"@en .

hariProject:core a owl:Ontology ;
    rdfs:label "Ontología principal del proyecto Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Ontología principal del proyecto Hari."@en ;
