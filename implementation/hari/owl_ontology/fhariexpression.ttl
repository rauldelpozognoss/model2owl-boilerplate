fhariexpression:Expression a owl:Class ;
    rdfs:isDefinedBy fhariexpression:core ;
    rdfs:subClassOf owl:Thing ;
    skos:prefLabel "Expression"@en .

fhariexpression:hasCardinalityRestrictionValue a owl:DatatypeProperty ;
    rdfs:isDefinedBy fhariexpression:core ;
    skos:prefLabel "has Cardinality Restriction Value"@en .

fhariexpression:hasCompositeExpression a owl:ObjectProperty ;
    rdfs:isDefinedBy fhariexpression:core ;
    skos:prefLabel "has Composite Expression"@en .

fhariexpression:hasDescription a owl:DatatypeProperty ;
    rdfs:isDefinedBy fhariexpression:core ;
    skos:prefLabel "has Description"@en .

fhariexpression:hasTargetValue a owl:DatatypeProperty ;
    rdfs:isDefinedBy fhariexpression:core ;
    skos:prefLabel "has Target Value"@en .

fhariexpression:isSelf a owl:DatatypeProperty ;
    rdfs:isDefinedBy fhariexpression:core ;
    skos:prefLabel "is Self"@en .

