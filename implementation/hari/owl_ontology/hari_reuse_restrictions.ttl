@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hari_reuse: <http://hari-meta.org/ontology/hari_reuse#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hari_reuse:core-restriction a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-04-21"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hari_reuse.xml on 
                2026-04-21""" ;
    owl:imports hari_reuse:core,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari_reuse#core-restriction-" ;
    owl:versionIRI hari_reuse:core-restriction-1.0.0 ;
    owl:versionInfo "1.0.0" .

hari_reuse:DirectReuseDecision rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari_reuse:hasReason ;
            owl:qualifiedCardinality 1 ] .

hari_reuse:hasReason a owl:FunctionalProperty ;
    rdfs:domain hari_reuse:DirectReuseDecision ;
    rdfs:range xsd:string .

