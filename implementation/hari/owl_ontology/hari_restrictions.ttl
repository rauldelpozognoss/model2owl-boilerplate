@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hari: <http://hari-meta.org/ontology/hari#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hari:core-restriction a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-05-12"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hari.xml on 
                2026-05-12""" ;
    owl:imports hari:core,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari#core-restriction-" ;
    owl:versionIRI hari:core-restriction-1.0.0 ;
    owl:versionInfo "1.0.0" .

hari:hasCompositeExpression a owl:AsymmetricProperty ;
    rdfs:domain hari:Expression ;
    rdfs:range hari:Expression .

hari:hasDisjointWith a owl:AsymmetricProperty ;
    rdfs:domain hari:Class ;
    rdfs:range hari:Class .

hari:hasEquivalentTo a owl:AsymmetricProperty ;
    rdfs:domain hari:Class ;
    rdfs:range hari:Class .

hari:hasExpressionTarget rdfs:domain hari:Expression ;
    rdfs:range hari:Types .

hari:hasExtension rdfs:domain hari:OntologyVersion ;
    rdfs:range hari:ExtensionDecision .

hari:hasKnowledgeDomain rdfs:domain hari:OntologyVersion ;
    rdfs:range hari:KnowledgeDomain .

hari:hasPropertyChain a owl:AsymmetricProperty ;
    rdfs:domain hari:ObjectProperty ;
    rdfs:range hari:ObjectProperty .

hari:hasReuse rdfs:domain hari:OntologyVersion ;
    rdfs:range hari:DirectReuseDecision .

hari:hasSubClassOf a owl:AsymmetricProperty ;
    rdfs:domain hari:Class ;
    rdfs:range hari:Class .

hari:hasSubPropertyOf a owl:AsymmetricProperty ;
    rdfs:domain hari:Property ;
    rdfs:range hari:Property .

hari:hasTermExample rdfs:domain hari:OntologicalTerm ;
    rdfs:range xsd:string .

hari:AnotationProperty rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:OntologicalTerm ;
            owl:onProperty hari:hasDomainAnotation ;
            owl:qualifiedCardinality 1 ] .

hari:Application rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Level ;
            owl:onProperty hari:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

hari:CardinalityRestriction rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:integer ;
            owl:onProperty hari:hasCardinalityValue ;
            owl:qualifiedCardinality 1 ] .

hari:ClassReuse rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Class ;
            owl:onProperty hari:hasClassReuse ;
            owl:qualifiedCardinality 1 ] .

hari:Core rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Level ;
            owl:onProperty hari:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

hari:DatatypeReuse rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Datatype ;
            owl:onProperty hari:hasDatatypeReuse ;
            owl:qualifiedCardinality 1 ] .

hari:Domain rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Level ;
            owl:onProperty hari:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

hari:Draft rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Status ;
            owl:onProperty hari:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

hari:ExpressionExtension rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Expression ;
            owl:onProperty hari:hasExpressionForExtension ;
            owl:qualifiedCardinality 1 ] .

hari:Foundational rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Level ;
            owl:onProperty hari:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

hari:HasSelf rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty hari:isSelf ;
            owl:qualifiedCardinality 1 ] .

hari:HasValue rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasTargetValue ;
            owl:qualifiedCardinality 1 ] .

hari:Obsolete rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Status ;
            owl:onProperty hari:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

hari:PropertyExtension rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Property ;
            owl:onProperty hari:hasPropertyExtension ;
            owl:qualifiedCardinality 1 ] .

hari:PropertyReuse rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Property ;
            owl:onProperty hari:hasPropertyReuse ;
            owl:qualifiedCardinality 1 ] .

hari:Restriction rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Property ;
            owl:onProperty hari:hasOnProperty ;
            owl:qualifiedCardinality 1 ] .

hari:Stable rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Status ;
            owl:onProperty hari:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

hari:hasAcronym a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyProject ;
    rdfs:range xsd:string .

hari:hasCardinalityValue a owl:FunctionalProperty ;
    rdfs:domain hari:CardinalityRestriction ;
    rdfs:range xsd:integer .

hari:hasClassReuse a owl:FunctionalProperty ;
    rdfs:domain hari:ClassReuse ;
    rdfs:range hari:Class .

hari:hasDatatypeReuse a owl:FunctionalProperty ;
    rdfs:domain hari:DatatypeReuse ;
    rdfs:range hari:Datatype .

hari:hasDescripcion a owl:FunctionalProperty ;
    rdfs:domain hari:Expression ;
    rdfs:range xsd:string .

hari:hasDescription a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyProject ;
    rdfs:range xsd:string .

hari:hasDomainAnotation a owl:FunctionalProperty ;
    rdfs:domain hari:AnotationProperty ;
    rdfs:range hari:OntologicalTerm .

hari:hasDomainClass a owl:FunctionalProperty ;
    rdfs:domain hari:ObjectProperty ;
    rdfs:range hari:Class .

hari:hasDomainDatatype a owl:FunctionalProperty ;
    rdfs:domain hari:DatatypeProperty ;
    rdfs:range hari:Class .

hari:hasExpression rdfs:domain hari:Types ;
    rdfs:range hari:Expression .

hari:hasExpressionForExtension a owl:FunctionalProperty ;
    rdfs:domain hari:ExpressionExtension ;
    rdfs:range hari:Expression .

hari:hasExtensionBaseClass a owl:FunctionalProperty ;
    rdfs:domain hari:ExtensionDecision ;
    rdfs:range hari:Class .

hari:hasExtensionExtendedClass a owl:FunctionalProperty ;
    rdfs:domain hari:ExtensionDecision ;
    rdfs:range hari:Class .

hari:hasExtensionReason rdfs:domain hari:ExtensionDecision ;
    rdfs:range xsd:string .

hari:hasInverseOf a owl:AsymmetricProperty ;
    rdfs:domain hari:ObjectProperty ;
    rdfs:range hari:ObjectProperty .

hari:hasLevel a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyProject ;
    rdfs:range hari:Level .

hari:hasOnProperty a owl:FunctionalProperty ;
    rdfs:domain hari:Restriction ;
    rdfs:range hari:Property .

hari:hasOntologyIRI a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyProject ;
    rdfs:range xsd:string .

hari:hasOrganization a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyProject ;
    rdfs:range xsd:string .

hari:hasPropertyExtension a owl:FunctionalProperty ;
    rdfs:domain hari:PropertyExtension ;
    rdfs:range hari:Property .

hari:hasPropertyReuse a owl:FunctionalProperty ;
    rdfs:domain hari:PropertyReuse ;
    rdfs:range hari:Property .

hari:hasRangeClass a owl:FunctionalProperty ;
    rdfs:domain hari:ObjectProperty ;
    rdfs:range hari:Class .

hari:hasRangeDatatype a owl:FunctionalProperty ;
    rdfs:domain hari:DatatypeProperty ;
    rdfs:range hari:Datatype .

hari:hasReuseReason rdfs:domain hari:DirectReuseDecision ;
    rdfs:range xsd:string .

hari:hasStatus a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyVersion ;
    rdfs:range hari:Status .

hari:hasTargetValue a owl:FunctionalProperty ;
    rdfs:domain hari:HasValue ;
    rdfs:range xsd:string .

hari:hasTermDefinition a owl:FunctionalProperty ;
    rdfs:domain hari:OntologicalTerm ;
    rdfs:range xsd:string .

hari:hasTermIRI a owl:FunctionalProperty ;
    rdfs:domain hari:OntologicalTerm ;
    rdfs:range xsd:string .

hari:hasTermLabel a owl:FunctionalProperty ;
    rdfs:domain hari:OntologicalTerm ;
    rdfs:range xsd:string .

hari:hasTitle a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyProject ;
    rdfs:range xsd:string .

hari:hasVersionIRI a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyVersion ;
    rdfs:range xsd:string .

hari:hasVersionInfo a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyVersion ;
    rdfs:range xsd:string .

hari:isAssymetric a owl:FunctionalProperty ;
    rdfs:domain hari:Property ;
    rdfs:range xsd:boolean .

hari:isDefinedIn a owl:FunctionalProperty ;
    rdfs:domain hari:OntologicalTerm ;
    rdfs:range hari:OntologyVersion .

hari:isFunctional a owl:FunctionalProperty ;
    rdfs:domain hari:Property ;
    rdfs:range xsd:boolean .

hari:isInverseFunctional a owl:FunctionalProperty ;
    rdfs:domain hari:Property ;
    rdfs:range xsd:boolean .

hari:isIrreflexive a owl:FunctionalProperty ;
    rdfs:domain hari:Property ;
    rdfs:range xsd:boolean .

hari:isReflexive a owl:FunctionalProperty ;
    rdfs:domain hari:Property ;
    rdfs:range xsd:boolean .

hari:isSelf a owl:FunctionalProperty ;
    rdfs:domain hari:HasSelf ;
    rdfs:range xsd:boolean .

hari:isSymmetric a owl:FunctionalProperty ;
    rdfs:domain hari:Property ;
    rdfs:range xsd:boolean .

hari:isTransitive a owl:FunctionalProperty ;
    rdfs:domain hari:Property ;
    rdfs:range xsd:boolean .

hari:isVersionOf a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyVersion ;
    rdfs:range hari:OntologyProject .

hari:DatatypeProperty rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Class ;
            owl:onProperty hari:hasDomainDatatype ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass hari:Datatype ;
            owl:onProperty hari:hasRangeDatatype ;
            owl:qualifiedCardinality 1 ] .

hari:DirectReuseDecision rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality 1 ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasReuseReason ] .

hari:Types rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality 1 ;
            owl:onClass hari:Expression ;
            owl:onProperty hari:hasExpression ] .

hari:ExtensionDecision rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Class ;
            owl:onProperty hari:hasExtensionExtendedClass ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass hari:Class ;
            owl:onProperty hari:hasExtensionBaseClass ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality 1 ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasExtensionReason ] .

hari:ObjectProperty rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality 1 ;
            owl:onClass hari:ObjectProperty ;
            owl:onProperty hari:hasInverseOf ],
        [ a owl:Restriction ;
            owl:onClass hari:Class ;
            owl:onProperty hari:hasDomainClass ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass hari:Class ;
            owl:onProperty hari:hasRangeClass ;
            owl:qualifiedCardinality 1 ] .

hari:OntologicalTerm rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasTermLabel ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass hari:OntologyVersion ;
            owl:onProperty hari:isDefinedIn ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasTermIRI ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasTermDefinition ;
            owl:qualifiedCardinality 1 ] .

hari:hasInScheme a owl:FunctionalProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hari:Foundational hari:Core hari:Domain hari:Application hari:Draft hari:Stable hari:Obsolete ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hari:Level hari:Status ) ] .

hari:Expression rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasDescripcion ;
            owl:qualifiedCardinality 1 ] .

hari:OntologyProject rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasDescription ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasAcronym ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass hari:Level ;
            owl:onProperty hari:hasLevel ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasOntologyIRI ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasTitle ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasOrganization ;
            owl:qualifiedCardinality 1 ] .

hari:OntologyVersion rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:Status ;
            owl:onProperty hari:hasStatus ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasVersionIRI ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass hari:OntologyProject ;
            owl:onProperty hari:isVersionOf ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasVersionInfo ;
            owl:qualifiedCardinality 1 ] .

hari:Property rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty hari:isReflexive ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty hari:isSymmetric ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty hari:isInverseFunctional ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty hari:isTransitive ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty hari:isAssymetric ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty hari:isIrreflexive ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty hari:isFunctional ;
            owl:qualifiedCardinality 1 ] .

