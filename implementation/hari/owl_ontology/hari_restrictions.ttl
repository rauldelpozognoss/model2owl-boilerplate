@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hari: <http://hari-meta.org/ontology/hari#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hari:core-restriction a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-04-07"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hari.xml on 
                2026-04-07""" ;
    owl:imports hari:core,
        dcterms:,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari#core-restriction-" ;
    owl:versionIRI hari:core-restriction-1.0.0 ;
    owl:versionInfo "1.0.0" .

hari:hasChange rdfs:domain hari:OntologyVersion ;
    rdfs:range hari:VersionChange .

hari:hasDependsOn a owl:AsymmetricProperty ;
    rdfs:domain hari:OntologyVersion ;
    rdfs:range hari:OntologyVersion .

hari:hasExtension rdfs:domain hari:OntologyVersion ;
    rdfs:range hari:ExtensionDecision .

hari:hasKnowledgeDomain rdfs:domain hari:OntologyVersion ;
    rdfs:range xsd:string .

hari:hasLevel rdfs:domain hari:OntologyProject ;
    rdfs:range hari:Level .

hari:hasReuse rdfs:domain hari:OntologyVersion ;
    rdfs:range hari:DirectReuseDecision .

hari:hasStatus rdfs:domain hari:OntologyVersion ;
    rdfs:range hari:Status .

hari:AttributeAddition rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasNewPropertyIRI ;
            owl:qualifiedCardinality 1 ] .

hari:AttributeExtension rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:ExternalTerm ;
            owl:onProperty hari:hasAddedProperty ;
            owl:qualifiedCardinality 1 ] .

hari:CardinalityExtension rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:ExternalTerm ;
            owl:onProperty hari:hasCardinalityChanged ;
            owl:qualifiedCardinality 1 ] .

hari:ClassReuse rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:ExternalTerm ;
            owl:onProperty hari:hasReusedClass ;
            owl:qualifiedCardinality 1 ] .

hari:PropertyReuse rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hari:ExternalTerm ;
            owl:onProperty hari:hasReusedProperty ;
            owl:qualifiedCardinality 1 ] .

hari:hasAcronym a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyProject ;
    rdfs:range xsd:string .

hari:hasAddedProperty a owl:FunctionalProperty ;
    rdfs:domain hari:AttributeExtension ;
    rdfs:range hari:ExternalTerm .

hari:hasBaseClass a owl:FunctionalProperty ;
    rdfs:domain hari:ExtensionDecision ;
    rdfs:range hari:ExternalTerm .

hari:hasCardinalityChanged a owl:FunctionalProperty ;
    rdfs:domain hari:CardinalityExtension ;
    rdfs:range hari:ExternalTerm .

hari:hasDate a owl:FunctionalProperty ;
    rdfs:domain hari:VersionChange ;
    rdfs:range xsd:date .

hari:hasDescription a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyProject ;
    rdfs:range xsd:string .

hari:hasExtendedClass a owl:FunctionalProperty ;
    rdfs:domain hari:ExtensionDecision ;
    rdfs:range hari:ExternalTerm .

hari:hasJustificacion rdfs:domain hari:ExtensionDecision ;
    rdfs:range xsd:string .

hari:hasNewMax a owl:FunctionalProperty ;
    rdfs:domain hari:CardinalityModification ;
    rdfs:range xsd:integer .

hari:hasNewMin a owl:FunctionalProperty ;
    rdfs:domain hari:CardinalityModification ;
    rdfs:range xsd:integer .

hari:hasNewPropertyIRI a owl:FunctionalProperty ;
    rdfs:domain hari:AttributeAddition ;
    rdfs:range xsd:string .

hari:hasOldMax a owl:FunctionalProperty ;
    rdfs:domain hari:CardinalityModification ;
    rdfs:range xsd:integer .

hari:hasOldMin a owl:FunctionalProperty ;
    rdfs:domain hari:CardinalityModification ;
    rdfs:range xsd:integer .

hari:hasOntologyIRI a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyProject ;
    rdfs:range xsd:string .

hari:hasOrganization a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyProject ;
    rdfs:range xsd:string .

hari:hasPriorVersionIRI rdfs:domain hari:OntologyVersion ;
    rdfs:range xsd:string .

hari:hasPropertyIRI a owl:FunctionalProperty ;
    rdfs:domain hari:CardinalityModification ;
    rdfs:range xsd:string .

hari:hasReason a owl:FunctionalProperty ;
    rdfs:domain hari:DirectReuseDecision ;
    rdfs:range xsd:string .

hari:hasReusedClass a owl:FunctionalProperty ;
    rdfs:domain hari:ClassReuse ;
    rdfs:range hari:ExternalTerm .

hari:hasReusedProperty a owl:FunctionalProperty ;
    rdfs:domain hari:PropertyReuse ;
    rdfs:range hari:ExternalTerm .

hari:hasTitle a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyProject ;
    rdfs:range xsd:string .

hari:hasVersionIRI a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyVersion ;
    rdfs:range xsd:string .

hari:hasVersionInfo a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyVersion ;
    rdfs:range xsd:string .

hari:isVersionOf a owl:FunctionalProperty ;
    rdfs:domain hari:OntologyVersion ;
    rdfs:range hari:OntologyProject .

hari:DirectReuseDecision rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasReason ;
            owl:qualifiedCardinality 1 ] .

hari:Level a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasValue hari:Level ;
            owl:onProperty skos:inScheme ] .

hari:Status a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasValue hari:Status ;
            owl:onProperty skos:inScheme ] .

hari:VersionChange rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:date ;
            owl:onProperty hari:hasDate ;
            owl:qualifiedCardinality 1 ] .

hari:ExtensionDecision rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality 1 ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasJustificacion ],
        [ a owl:Restriction ;
            owl:onClass hari:ExternalTerm ;
            owl:onProperty hari:hasExtendedClass ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass hari:ExternalTerm ;
            owl:onProperty hari:hasBaseClass ;
            owl:qualifiedCardinality 1 ] .

hari:CardinalityModification rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:integer ;
            owl:onProperty hari:hasOldMin ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:integer ;
            owl:onProperty hari:hasNewMin ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:integer ;
            owl:onProperty hari:hasOldMax ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasPropertyIRI ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:integer ;
            owl:onProperty hari:hasNewMax ;
            owl:qualifiedCardinality 1 ] .

hari:OntologyProject rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasOntologyIRI ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasDescription ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasTitle ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasOrganization ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasAcronym ;
            owl:qualifiedCardinality 1 ] .

hari:OntologyVersion rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasVersionInfo ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass hari:OntologyProject ;
            owl:onProperty hari:isVersionOf ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality 1 ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasPriorVersionIRI ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari:hasVersionIRI ;
            owl:qualifiedCardinality 1 ] .

