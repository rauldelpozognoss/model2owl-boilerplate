@prefix core-res: <http://hari-meta.org/ontology/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-res:core-restriction a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-04-15"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hari.xml on 
                2026-04-15""" ;
    owl:imports core-res:core,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari#core-restriction-" ;
    owl:versionIRI core-res:core-restriction-1.0.0 ;
    owl:versionInfo "1.0.0" .

core-res:hasDisjointWith a owl:AsymmetricProperty ;
    rdfs:domain core-res:Class ;
    rdfs:range core-res:Class .

core-res:hasEquivalentTo a owl:AsymmetricProperty ;
    rdfs:domain core-res:Class ;
    rdfs:range core-res:Class .

core-res:hasExtension rdfs:domain core-res:OntologyVersion ;
    rdfs:range core-res:ExtensionDecision .

core-res:hasKnowledgeDomain rdfs:domain core-res:OntologyVersion ;
    rdfs:range xsd:string .

core-res:hasRestriction rdfs:domain core-res:Class ;
    rdfs:range core-res:Restriction .

core-res:hasReuse rdfs:domain core-res:OntologyVersion ;
    rdfs:range core-res:DirectReuseDecision .

core-res:hasSubClassOf a owl:AsymmetricProperty ;
    rdfs:domain core-res:Class ;
    rdfs:range core-res:Class .

core-res:hasSubPropertyOf a owl:AsymmetricProperty ;
    rdfs:domain core-res:Property ;
    rdfs:range core-res:Property .

core-res:hasTermExample rdfs:domain core-res:OntologicalTerm ;
    rdfs:range xsd:string .

core-res:AnotationProperty rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:OntologicalTerm ;
            owl:onProperty core-res:hasDomainAnotation ;
            owl:qualifiedCardinality 1 ] .

core-res:Application rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Level ;
            owl:onProperty core-res:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

core-res:ClassReuse rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Class ;
            owl:onProperty core-res:hasClassReuse ;
            owl:qualifiedCardinality 1 ] .

core-res:ConstraintExtension rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Restriction ;
            owl:onProperty core-res:hasConstraintExtension ;
            owl:qualifiedCardinality 1 ] .

core-res:Core rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Level ;
            owl:onProperty core-res:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

core-res:Domain rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Level ;
            owl:onProperty core-res:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

core-res:Draft rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Status ;
            owl:onProperty core-res:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

core-res:Foundational rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Level ;
            owl:onProperty core-res:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

core-res:HasSelf rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty core-res:isSelf ;
            owl:qualifiedCardinality 1 ] .

core-res:HasValue rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty core-res:hasTargetValue ;
            owl:qualifiedCardinality 1 ] .

core-res:Obsolete rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Status ;
            owl:onProperty core-res:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

core-res:PropertyExtension rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Property ;
            owl:onProperty core-res:hasPropertyExtension ;
            owl:qualifiedCardinality 1 ] .

core-res:PropertyReuse rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Property ;
            owl:onProperty core-res:hasPropertyReuse ;
            owl:qualifiedCardinality 1 ] .

core-res:Stable rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Status ;
            owl:onProperty core-res:hasInScheme ;
            owl:qualifiedCardinality 1 ] .

core-res:ValuesFrom rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Types ;
            owl:onProperty core-res:hasValuesFrom ;
            owl:qualifiedCardinality 1 ] .

core-res:hasAcronym a owl:FunctionalProperty ;
    rdfs:domain core-res:OntologyProject ;
    rdfs:range xsd:string .

core-res:hasCardinalityValue a owl:FunctionalProperty ;
    rdfs:domain core-res:CardinalityRestriction ;
    rdfs:range xsd:integer .

core-res:hasClassReuse a owl:FunctionalProperty ;
    rdfs:domain core-res:ClassReuse ;
    rdfs:range core-res:Class .

core-res:hasConstraintExtension a owl:FunctionalProperty ;
    rdfs:domain core-res:ConstraintExtension ;
    rdfs:range core-res:Restriction .

core-res:hasDescription a owl:FunctionalProperty ;
    rdfs:domain core-res:OntologyProject ;
    rdfs:range xsd:string .

core-res:hasDomainAnotation a owl:FunctionalProperty ;
    rdfs:domain core-res:AnotationProperty ;
    rdfs:range core-res:OntologicalTerm .

core-res:hasDomainClass a owl:FunctionalProperty ;
    rdfs:domain core-res:ObjectProperty ;
    rdfs:range core-res:Class .

core-res:hasDomainDatatype a owl:FunctionalProperty ;
    rdfs:domain core-res:DatatypeProperty ;
    rdfs:range core-res:Class .

core-res:hasExtensionBaseClass a owl:FunctionalProperty ;
    rdfs:domain core-res:ExtensionDecision ;
    rdfs:range core-res:Class .

core-res:hasExtensionExtendedClass a owl:FunctionalProperty ;
    rdfs:domain core-res:ExtensionDecision ;
    rdfs:range core-res:Class .

core-res:hasInverseOf a owl:AsymmetricProperty ;
    rdfs:domain core-res:ObjectProperty ;
    rdfs:range core-res:ObjectProperty .

core-res:hasJustificacion rdfs:domain core-res:ExtensionDecision ;
    rdfs:range xsd:string .

core-res:hasLevel a owl:FunctionalProperty ;
    rdfs:domain core-res:OntologyProject ;
    rdfs:range core-res:Level .

core-res:hasOnProperty a owl:FunctionalProperty ;
    rdfs:domain core-res:Restriction ;
    rdfs:range core-res:Property .

core-res:hasOntologyIRI a owl:FunctionalProperty ;
    rdfs:domain core-res:OntologyProject ;
    rdfs:range xsd:string .

core-res:hasOrganization a owl:FunctionalProperty ;
    rdfs:domain core-res:OntologyProject ;
    rdfs:range xsd:string .

core-res:hasPriorVersionIRI rdfs:domain core-res:OntologyVersion ;
    rdfs:range xsd:string .

core-res:hasPropertyExtension a owl:FunctionalProperty ;
    rdfs:domain core-res:PropertyExtension ;
    rdfs:range core-res:Property .

core-res:hasPropertyReuse a owl:FunctionalProperty ;
    rdfs:domain core-res:PropertyReuse ;
    rdfs:range core-res:Property .

core-res:hasQualifiedTarget a owl:FunctionalProperty ;
    rdfs:domain core-res:CardinalityRestriction ;
    rdfs:range core-res:Types .

core-res:hasRangeClass a owl:FunctionalProperty ;
    rdfs:domain core-res:ObjectProperty ;
    rdfs:range core-res:Class .

core-res:hasRangeDatatype a owl:FunctionalProperty ;
    rdfs:domain core-res:DatatypeProperty ;
    rdfs:range core-res:Datatype .

core-res:hasReason a owl:FunctionalProperty ;
    rdfs:domain core-res:DirectReuseDecision ;
    rdfs:range xsd:string .

core-res:hasStatus a owl:FunctionalProperty ;
    rdfs:domain core-res:OntologyVersion ;
    rdfs:range core-res:Status .

core-res:hasTargetValue a owl:FunctionalProperty ;
    rdfs:domain core-res:HasValue ;
    rdfs:range xsd:string .

core-res:hasTermDefinition a owl:FunctionalProperty ;
    rdfs:domain core-res:OntologicalTerm ;
    rdfs:range xsd:string .

core-res:hasTermIRI a owl:FunctionalProperty ;
    rdfs:domain core-res:OntologicalTerm ;
    rdfs:range xsd:string .

core-res:hasTermLabel a owl:FunctionalProperty ;
    rdfs:domain core-res:OntologicalTerm ;
    rdfs:range xsd:string .

core-res:hasTitle a owl:FunctionalProperty ;
    rdfs:domain core-res:OntologyProject ;
    rdfs:range xsd:string .

core-res:hasValuesFrom a owl:FunctionalProperty ;
    rdfs:domain core-res:ValuesFrom ;
    rdfs:range core-res:Types .

core-res:hasVersionIRI a owl:FunctionalProperty ;
    rdfs:domain core-res:OntologyVersion ;
    rdfs:range xsd:string .

core-res:hasVersionInfo a owl:FunctionalProperty ;
    rdfs:domain core-res:OntologyVersion ;
    rdfs:range xsd:string .

core-res:isDefinedIn a owl:FunctionalProperty ;
    rdfs:domain core-res:OntologicalTerm ;
    rdfs:range core-res:OntologyVersion .

core-res:isFunctional a owl:FunctionalProperty ;
    rdfs:domain core-res:Property ;
    rdfs:range xsd:boolean .

core-res:isSelf a owl:FunctionalProperty ;
    rdfs:domain core-res:HasSelf ;
    rdfs:range xsd:boolean .

core-res:isSymmetric a owl:FunctionalProperty ;
    rdfs:domain core-res:Property ;
    rdfs:range xsd:boolean .

core-res:isTransitive a owl:FunctionalProperty ;
    rdfs:domain core-res:Property ;
    rdfs:range xsd:boolean .

core-res:isVersionOf a owl:FunctionalProperty ;
    rdfs:domain core-res:OntologyVersion ;
    rdfs:range core-res:OntologyProject .

core-res:CardinalityRestriction rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:integer ;
            owl:onProperty core-res:hasCardinalityValue ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass core-res:Types ;
            owl:onProperty core-res:hasQualifiedTarget ;
            owl:qualifiedCardinality 1 ] .

core-res:DatatypeProperty rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Datatype ;
            owl:onProperty core-res:hasRangeDatatype ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass core-res:Class ;
            owl:onProperty core-res:hasDomainDatatype ;
            owl:qualifiedCardinality 1 ] .

core-res:DirectReuseDecision rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty core-res:hasReason ;
            owl:qualifiedCardinality 1 ] .

core-res:ExtensionDecision rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality 1 ;
            owl:onDataRange xsd:string ;
            owl:onProperty core-res:hasJustificacion ],
        [ a owl:Restriction ;
            owl:onClass core-res:Class ;
            owl:onProperty core-res:hasExtensionExtendedClass ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass core-res:Class ;
            owl:onProperty core-res:hasExtensionBaseClass ;
            owl:qualifiedCardinality 1 ] .

core-res:Restriction rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Property ;
            owl:onProperty core-res:hasOnProperty ;
            owl:qualifiedCardinality 1 ] .

core-res:ObjectProperty rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:Class ;
            owl:onProperty core-res:hasRangeClass ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass core-res:Class ;
            owl:onProperty core-res:hasDomainClass ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality 1 ;
            owl:onClass core-res:ObjectProperty ;
            owl:onProperty core-res:hasInverseOf ] .

core-res:OntologicalTerm rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty core-res:hasTermDefinition ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass core-res:OntologyVersion ;
            owl:onProperty core-res:isDefinedIn ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty core-res:hasTermLabel ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty core-res:hasTermIRI ;
            owl:qualifiedCardinality 1 ] .

core-res:hasInScheme a owl:FunctionalProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( core-res:Foundational core-res:Core core-res:Domain core-res:Application core-res:Draft core-res:Stable core-res:Obsolete ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( core-res:Level core-res:Status ) ] .

core-res:OntologyProject rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty core-res:hasOntologyIRI ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty core-res:hasDescription ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty core-res:hasTitle ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty core-res:hasAcronym ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass core-res:Level ;
            owl:onProperty core-res:hasLevel ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty core-res:hasOrganization ;
            owl:qualifiedCardinality 1 ] .

core-res:OntologyVersion rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass core-res:OntologyProject ;
            owl:onProperty core-res:isVersionOf ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty core-res:hasVersionIRI ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty core-res:hasVersionInfo ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass core-res:Status ;
            owl:onProperty core-res:hasStatus ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality 1 ;
            owl:onDataRange xsd:string ;
            owl:onProperty core-res:hasPriorVersionIRI ] .

core-res:Property rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty core-res:isFunctional ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty core-res:isTransitive ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty core-res:isSymmetric ;
            owl:qualifiedCardinality 1 ] .

