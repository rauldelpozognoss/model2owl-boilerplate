@prefix core-res: <http://hari-meta.org/ontology/hari#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hari_extension: <http://hari-meta.org/ontology/hari_extension#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hari_extension:ConstraintExtension a owl:Class ;
    rdfs:isDefinedBy core-res:core ;
    rdfs:subClassOf hari_extension:ExtensionDecision ;
    skos:prefLabel "Constraint Extension"@en .

hari_extension:PropertyExtension a owl:Class ;
    rdfs:isDefinedBy core-res:core ;
    rdfs:subClassOf hari_extension:ExtensionDecision ;
    skos:prefLabel "Property Extension"@en .

hari_extension:SemanticExtension a owl:Class ;
    rdfs:isDefinedBy core-res:core ;
    rdfs:subClassOf hari_extension:ExtensionDecision ;
    skos:prefLabel "Semantic Extension"@en .

hari_extension:hasJustificacion a owl:DatatypeProperty ;
    rdfs:isDefinedBy core-res:core ;
    skos:prefLabel "has Justificacion"@en .

hari_extension:Thing a owl:Class ;
    rdfs:isDefinedBy core-res:core ;
    skos:definition "Clase raíz del metamodelo. Todas las clases diseñadas cuelgan de aquí."@en ;
    skos:prefLabel "Thing"@en .

hari_extension:ExtensionDecision a owl:Class ;
    rdfs:isDefinedBy core-res:core ;
    rdfs:subClassOf hari_extension:Thing ;
    skos:prefLabel "Extension Decision"@en .

core-res:core a owl:Ontology ;
    rdfs:label "Ontología principal del proyecto Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Ontología principal del proyecto Hari."@en ;
    dcterms:issued "2026-04-15"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Core"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from hari_extension.xml on 2026-04-15" ;
    owl:imports skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari#core-" ;
    owl:versionIRI core-res:core-1.0.0 ;
    owl:versionInfo "1.0.0" .

