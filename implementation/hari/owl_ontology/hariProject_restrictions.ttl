@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hariProject: <http://hari-meta.org/ontology/hariProject#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hariProject:core-restriction a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-05-12"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hariProject.xml on 
                2026-05-12""" ;
    owl:imports hariProject:core,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hariProject#core-restriction-" ;
    owl:versionIRI hariProject:core-restriction-1.0.0 ;
    owl:versionInfo "1.0.0" .

hariProject:hasAcronym a owl:FunctionalProperty ;
    rdfs:domain hariProject:OntologyProject ;
    rdfs:range xsd:string .

hariProject:hasDescription a owl:FunctionalProperty ;
    rdfs:domain hariProject:OntologyProject ;
    rdfs:range xsd:string .

hariProject:hasOntologyIRI a owl:FunctionalProperty ;
    rdfs:domain hariProject:OntologyProject ;
    rdfs:range xsd:string .

hariProject:hasOrganization a owl:FunctionalProperty ;
    rdfs:domain hariProject:OntologyProject ;
    rdfs:range xsd:string .

hariProject:hasTitle a owl:FunctionalProperty ;
    rdfs:domain hariProject:OntologyProject ;
    rdfs:range xsd:string .

hariProject:OntologyProject rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hariProject:hasTitle ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hariProject:hasAcronym ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hariProject:hasDescription ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hariProject:hasOrganization ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hariProject:hasOntologyIRI ;
            owl:qualifiedCardinality 1 ] .

