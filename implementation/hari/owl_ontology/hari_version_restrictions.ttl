@prefix : <http://hari-meta.org/ontology/hari_version#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:core-restriction a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-04-29"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hari_version.xml on 
                2026-04-29""" ;
    owl:imports :core,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari_version#core-restriction-" ;
    owl:versionIRI :core-restriction-1.0.0 ;
    owl:versionInfo "1.0.0" .

:hasVersionIRI a owl:FunctionalProperty ;
    rdfs:domain :OntologyVersion ;
    rdfs:range xsd:string .

:hasVersionInfo a owl:FunctionalProperty ;
    rdfs:domain :OntologyVersion ;
    rdfs:range xsd:string .

:OntologyVersion rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty :hasVersionIRI ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty :hasVersionInfo ;
            owl:qualifiedCardinality 1 ] .

