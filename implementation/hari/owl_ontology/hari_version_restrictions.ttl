    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hari_version.xml on 
                2026-05-08""" ;
    owl:imports <http://hari-meta.org/ontology/hari_version#core>,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari_version#core-restriction-" ;
    owl:versionIRI <http://hari-meta.org/ontology/hari_version#core-restriction-1.0.0> ;
    owl:versionInfo "1.0.0" .

<http://hari-meta.org/ontology/hari_version#hasVersionIRI> a owl:FunctionalProperty ;
    rdfs:domain <http://hari-meta.org/ontology/hari_version#OntologyVersion> ;
    rdfs:range xsd:string .

<http://hari-meta.org/ontology/hari_version#hasVersionInfo> a owl:FunctionalProperty ;
    rdfs:domain <http://hari-meta.org/ontology/hari_version#OntologyVersion> ;
    rdfs:range xsd:string .

<http://hari-meta.org/ontology/hari_version#OntologyVersion> rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty <http://hari-meta.org/ontology/hari_version#hasVersionInfo> ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty <http://hari-meta.org/ontology/hari_version#hasVersionIRI> ;
            owl:qualifiedCardinality 1 ] .

