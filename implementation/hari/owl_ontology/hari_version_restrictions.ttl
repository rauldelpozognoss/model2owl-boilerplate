@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hari: <http://hari-meta.org/ontology/hari#> .
@prefix hari_version: <http://hari-meta.org/ontology/hari_version#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hari:core-restriction a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-04-15"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hari_version.xml on 
                2026-04-15""" ;
    owl:imports hari:core,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari#core-restriction-" ;
    owl:versionIRI hari:core-restriction-1.0.0 ;
    owl:versionInfo "1.0.0" .

hari_version:hasKnowledgeDomain rdfs:domain hari_version:OntologyVersion ;
    rdfs:range xsd:string .

hari_version:hasPriorVersionIRI rdfs:domain hari_version:OntologyVersion ;
    rdfs:range xsd:string .

hari_version:hasVersionIRI a owl:FunctionalProperty ;
    rdfs:domain hari_version:OntologyVersion ;
    rdfs:range xsd:string .

hari_version:hasVersionInfo a owl:FunctionalProperty ;
    rdfs:domain hari_version:OntologyVersion ;
    rdfs:range xsd:string .

hari_version:OntologyVersion rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari_version:hasVersionIRI ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari_version:hasVersionInfo ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality 1 ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari_version:hasPriorVersionIRI ] .

