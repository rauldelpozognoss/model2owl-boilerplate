@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hari_project: <http://hari-meta.org/ontology/hari_project#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hari_project:core-restriction a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-04-21"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hari_project.xml on 
                2026-04-21""" ;
    owl:imports hari_project:core,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari_project#core-restriction-" ;
    owl:versionIRI hari_project:core-restriction-1.0.0 ;
    owl:versionInfo "1.0.0" .

hari_project:hasAcronym a owl:FunctionalProperty ;
    rdfs:domain hari_project:OntologyProject ;
    rdfs:range xsd:string .

hari_project:hasDescription a owl:FunctionalProperty ;
    rdfs:domain hari_project:OntologyProject ;
    rdfs:range xsd:string .

hari_project:hasOntologyIRI a owl:FunctionalProperty ;
    rdfs:domain hari_project:OntologyProject ;
    rdfs:range xsd:string .

hari_project:hasOrganization a owl:FunctionalProperty ;
    rdfs:domain hari_project:OntologyProject ;
    rdfs:range xsd:string .

hari_project:hasTitle a owl:FunctionalProperty ;
    rdfs:domain hari_project:OntologyProject ;
    rdfs:range xsd:string .

hari_project:OntologyProject rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari_project:hasDescription ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari_project:hasAcronym ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari_project:hasTitle ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari_project:hasOntologyIRI ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hari_project:hasOrganization ;
            owl:qualifiedCardinality 1 ] .

