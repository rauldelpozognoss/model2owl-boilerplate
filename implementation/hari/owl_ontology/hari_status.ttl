hari_status:Draft a owl:Class ;
    rdfs:isDefinedBy core-res:core ;
    rdfs:subClassOf hari_status:Thing ;
    skos:prefLabel "Draft"@en .

hari_status:Obsolete a owl:Class ;
    rdfs:isDefinedBy core-res:core ;
    rdfs:subClassOf hari_status:Thing ;
    skos:prefLabel "Obsolete"@en .

hari_status:Stable a owl:Class ;
    rdfs:isDefinedBy core-res:core ;
    rdfs:subClassOf hari_status:Thing ;
    skos:prefLabel "Stable"@en .

hari_status:Status a owl:Class ;
    rdfs:isDefinedBy core-res:core ;
    rdfs:subClassOf hari_status:Thing ;
    skos:prefLabel "Status"@en .

hari_status:hasInScheme a owl:ObjectProperty ;
    rdfs:isDefinedBy core-res:core ;
    skos:prefLabel "has In Scheme"@en .

hari_status:Thing a owl:Class ;
    rdfs:isDefinedBy core-res:core ;
    skos:definition "Clase raíz del metamodelo. Todas las clases diseñadas cuelgan de aquí."@en ;
    skos:prefLabel "Thing"@en .

