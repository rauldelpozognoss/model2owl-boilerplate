@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hariversion: <http://hari-meta.org/ontology/hariversion#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://hari-meta.org/ontology/hariVersion#core-restriction> a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-05-13"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hariVersion.xml on 
                2026-05-13""" ;
    owl:imports <http://hari-meta.org/ontology/hariVersion#core>,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hariVersion#core-restriction-" ;
    owl:versionIRI <http://hari-meta.org/ontology/hariVersion#core-restriction-1.0.0> ;
    owl:versionInfo "1.0.0" .

hariversion:hasVersionIRI a owl:FunctionalProperty ;
    rdfs:domain hariversion:OntologyVersion ;
    rdfs:range xsd:string .

hariversion:hasVersionInfo a owl:FunctionalProperty ;
    rdfs:domain hariversion:OntologyVersion ;
    rdfs:range xsd:string .

hariversion:OntologyVersion rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hariversion:hasVersionInfo ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty hariversion:hasVersionIRI ;
            owl:qualifiedCardinality 1 ] .

