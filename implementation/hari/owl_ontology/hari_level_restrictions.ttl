@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://hari-meta.org/ontology/hari_level#core-restriction> a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-05-08"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hari_level.xml on 
                2026-05-08""" ;
    owl:imports <http://hari-meta.org/ontology/hari_level#core>,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari_level#core-restriction-" ;
    owl:versionIRI <http://hari-meta.org/ontology/hari_level#core-restriction-1.0.0> ;
    owl:versionInfo "1.0.0" .

<http://hari-meta.org/ontology/hari_level#Application> rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass <http://hari-meta.org/ontology/hari_level#Level> ;
            owl:onProperty <http://hari-meta.org/ontology/hari_level#hasInScheme> ;
            owl:qualifiedCardinality 1 ] .

<http://hari-meta.org/ontology/hari_level#Core> rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass <http://hari-meta.org/ontology/hari_level#Level> ;
            owl:onProperty <http://hari-meta.org/ontology/hari_level#hasInScheme> ;
            owl:qualifiedCardinality 1 ] .

<http://hari-meta.org/ontology/hari_level#Domain> rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass <http://hari-meta.org/ontology/hari_level#Level> ;
            owl:onProperty <http://hari-meta.org/ontology/hari_level#hasInScheme> ;
            owl:qualifiedCardinality 1 ] .

<http://hari-meta.org/ontology/hari_level#Foundational> rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass <http://hari-meta.org/ontology/hari_level#Level> ;
            owl:onProperty <http://hari-meta.org/ontology/hari_level#hasInScheme> ;
            owl:qualifiedCardinality 1 ] .

<http://hari-meta.org/ontology/hari_level#hasInScheme> a owl:FunctionalProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <http://hari-meta.org/ontology/hari_level#Foundational> <http://hari-meta.org/ontology/hari_level#Core> <http://hari-meta.org/ontology/hari_level#Domain> <http://hari-meta.org/ontology/hari_level#Application> ) ] ;
    rdfs:range <http://hari-meta.org/ontology/hari_level#Level> .

