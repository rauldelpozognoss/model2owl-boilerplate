    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Core"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment "This version is automatically generated from hari_scope.xml on 2026-04-21" ;
    owl:imports skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari_scope#core-" ;
    owl:versionIRI hari_scope:core-1.0.0 ;
    owl:versionInfo "1.0.0" .

