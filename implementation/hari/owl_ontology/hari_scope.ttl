hari_scope:KnowledgeDomain a owl:Class ;
    rdfs:isDefinedBy hari_scope:core ;
    rdfs:subClassOf hari_scope:Thing ;
    skos:prefLabel "Knowledge Domain"@en .

hari_scope:Thing a owl:Class ;
    rdfs:isDefinedBy hari_scope:core ;
    skos:definition "Clase raíz del metamodelo. Todas las clases diseñadas cuelgan de aquí."@en ;
    skos:prefLabel "Thing"@en .

hari_scope:core a owl:Ontology ;
    rdfs:label "Ontología principal del proyecto Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Ontología principal del proyecto Hari."@en ;
