@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fhariproject: <http://hari-meta.org/ontology/fhariproject#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

fhariproject:core-restriction a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-05-14"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from fhariproject.xml on 
                2026-05-14""" ;
    owl:imports fhariproject:core,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/fhariproject#core-restriction-" ;
    owl:versionIRI fhariproject:core-restriction-1.0.0 ;
    owl:versionInfo "1.0.0" .

fhariproject:hasAcronym a owl:FunctionalProperty ;
    rdfs:domain fhariproject:OntologyProject ;
    rdfs:range xsd:string .

fhariproject:hasDescription a owl:FunctionalProperty ;
    rdfs:domain fhariproject:OntologyProject ;
    rdfs:range xsd:string .

fhariproject:hasOntologyIRI a owl:FunctionalProperty ;
    rdfs:domain fhariproject:OntologyProject ;
    rdfs:range xsd:string .

fhariproject:hasOrganization a owl:FunctionalProperty ;
    rdfs:domain fhariproject:OntologyProject ;
    rdfs:range xsd:string .

fhariproject:hasTitle a owl:FunctionalProperty ;
    rdfs:domain fhariproject:OntologyProject ;
    rdfs:range xsd:string .

fhariproject:OntologyProject rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty fhariproject:hasTitle ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty fhariproject:hasOrganization ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty fhariproject:hasDescription ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty fhariproject:hasOntologyIRI ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty fhariproject:hasAcronym ;
            owl:qualifiedCardinality 1 ] .

