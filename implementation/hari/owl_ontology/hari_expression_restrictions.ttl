@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://hari-meta.org/ontology/hari_expression#core-restriction> a owl:Ontology ;
    rdfs:label "Restricciones de la ontología Hari."@en ;
    dcterms:created "2026-03-26"^^xsd:date ;
    dcterms:description "Restricciones de la ontología Hari."@en ;
    dcterms:issued "2026-05-08"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://hari-meta.org" ;
    dcterms:title "Ontología Hari Restricciones"@en ;
    vann:preferredNamespacePrefix "hari" ;
    vann:preferredNamespaceUri "http://hari-meta.org/ontology/hari#" ;
    rdfs:comment """This version is automatically generated from hari_expression.xml on 
                2026-05-08""" ;
    owl:imports <http://hari-meta.org/ontology/hari_expression#core>,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://hari-meta.org/ontology/hari_expression#core-restriction-" ;
    owl:versionIRI <http://hari-meta.org/ontology/hari_expression#core-restriction-1.0.0> ;
    owl:versionInfo "1.0.0" .

<http://hari-meta.org/ontology/hari_expression#hasCompositeExpression> a owl:AsymmetricProperty ;
    rdfs:domain <http://hari-meta.org/ontology/hari_expression#Expression> ;
    rdfs:range <http://hari-meta.org/ontology/hari_expression#Expression> .

<http://hari-meta.org/ontology/hari_expression#CardinalityRestriction> rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:integer ;
            owl:onProperty <http://hari-meta.org/ontology/hari_expression#hasCardinalityValue> ;
            owl:qualifiedCardinality 1 ] .

<http://hari-meta.org/ontology/hari_expression#HasSelf> rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty <http://hari-meta.org/ontology/hari_expression#isSelf> ;
            owl:qualifiedCardinality 1 ] .

<http://hari-meta.org/ontology/hari_expression#HasValue> rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty <http://hari-meta.org/ontology/hari_expression#hasTargetValue> ;
            owl:qualifiedCardinality 1 ] .

<http://hari-meta.org/ontology/hari_expression#hasCardinalityValue> a owl:FunctionalProperty ;
    rdfs:domain <http://hari-meta.org/ontology/hari_expression#CardinalityRestriction> ;
    rdfs:range xsd:integer .

<http://hari-meta.org/ontology/hari_expression#hasDescription> a owl:FunctionalProperty ;
    rdfs:domain <http://hari-meta.org/ontology/hari_expression#Expression> ;
    rdfs:range xsd:string .

<http://hari-meta.org/ontology/hari_expression#hasTargetValue> a owl:FunctionalProperty ;
    rdfs:domain <http://hari-meta.org/ontology/hari_expression#HasValue> ;
    rdfs:range xsd:string .

<http://hari-meta.org/ontology/hari_expression#isSelf> a owl:FunctionalProperty ;
    rdfs:domain <http://hari-meta.org/ontology/hari_expression#HasSelf> ;
    rdfs:range xsd:boolean .

<http://hari-meta.org/ontology/hari_expression#Expression> rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty <http://hari-meta.org/ontology/hari_expression#hasDescription> ;
            owl:qualifiedCardinality 1 ] .

