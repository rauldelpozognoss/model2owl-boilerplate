@prefix core-shape: <http://tu-dominio.com/ontologia/prueba-shape#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prueba: <http://tu-dominio.com/ontologia/prueba#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core-shape:prueba-CartaShape a sh:NodeShape ;
    rdfs:label "Carta" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:prueba-Carta-prueba-hasFechaSalida,
        core-shape:prueba-Carta-prueba-hasNombre,
        core-shape:prueba-Carta-prueba-hasTipoCarta ;
    sh:sparql [ sh:select """SELECT ?this WHERE { ?this a <http://tu-dominio.com/ontologia/prueba#Carta> .
                }""" ] ;
    sh:targetClass prueba:Carta .

core-shape:prueba-InstanciaCartaShape a sh:NodeShape ;
    rdfs:label "Instancia Carta" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:prueba-InstanciaCarta-prueba-hasId,
        core-shape:prueba-InstanciaCarta-prueba-hasImagen,
        core-shape:prueba-InstanciaCarta-prueba-hasStats,
        core-shape:prueba-InstanciaCarta-prueba-hasVersion ;
    sh:targetClass prueba:InstanciaCarta .

core-shape:prueba-JuegoDeCartasShape a sh:NodeShape ;
    rdfs:label "Juego De Cartas" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:prueba-JuegoDeCartas-prueba-hasCartas,
        core-shape:prueba-JuegoDeCartas-prueba-hasId,
        core-shape:prueba-JuegoDeCartas-prueba-hasJuego,
        core-shape:prueba-JuegoDeCartas-prueba-hasNombre ;
    sh:targetClass prueba:JuegoDeCartas .

core-shape:prueba-JuegoShape a sh:NodeShape ;
    rdfs:label "Juego" ;
    rdfs:comment "Descripción de Juego: Es una actividad lúdica." ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:prueba-Juego-prueba-hasComponentes ;
    sh:targetClass prueba:Juego .

core-shape:prueba-JugadorShape a sh:NodeShape ;
    rdfs:label "Jugador" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:prueba-Jugador-prueba-hasEsPropietario ;
    sh:targetClass prueba:Jugador .

core-shape:prueba-PartidaShape a sh:NodeShape ;
    rdfs:label "Partida" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:prueba-Partida-prueba-hasJugadores,
        core-shape:prueba-Partida-prueba-hasPartidaDeJuego ;
    sh:targetClass prueba:Partida .

core-shape:prueba-PersonaShape a sh:NodeShape ;
    rdfs:label "Persona" ;
    rdfs:comment "Descripción: Una persona con DNI. Nota: Dudas sobre Persona Nota: después de los tags" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:property core-shape:prueba-Persona-prueba-hasDni,
        core-shape:prueba-Persona-prueba-hasFechaNacimiento,
        core-shape:prueba-Persona-prueba-hasNombre ;
    sh:targetClass prueba:Persona .

core-shape:prueba-ThingShape a sh:NodeShape ;
    rdfs:label "Thing" ;
    rdfs:comment "Clase raíz del metamodelo. Todas las clases diseñadas cuelgan de aquí." ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass prueba:Thing .

core-shape:prueba-YugiohShape a sh:NodeShape ;
    rdfs:label "Yugioh" ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:targetClass prueba:Yugioh .

core-shape:prueba-Carta-prueba-hasFechaSalida a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:date ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has fecha salida" ;
    sh:path prueba:hasFechaSalida .

core-shape:prueba-Carta-prueba-hasNombre a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has nombre" ;
    sh:path prueba:hasNombre .

core-shape:prueba-Carta-prueba-hasTipoCarta a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class prueba:TipoCarta ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has tipo carta" ;
    sh:path prueba:hasTipoCarta ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://tu-dominio.com/ontologia/prueba#hasTipoCarta> ?that . ?that <http://tu-dominio.com/ontologia/prueba#hasTipoCarta> ?this .}" ] .

core-shape:prueba-InstanciaCarta-prueba-hasId a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has id" ;
    sh:path prueba:hasId .

core-shape:prueba-InstanciaCarta-prueba-hasImagen a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:name "Has imagen" ;
    sh:path prueba:hasImagen .

core-shape:prueba-InstanciaCarta-prueba-hasStats a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:name "Has stats" ;
    sh:path prueba:hasStats .

core-shape:prueba-InstanciaCarta-prueba-hasVersion a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:name "Has version" ;
    sh:path prueba:hasVersion .

core-shape:prueba-Juego-prueba-hasComponentes a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has componentes" ;
    sh:path prueba:hasComponentes .

core-shape:prueba-JuegoDeCartas-prueba-hasCartas a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class prueba:Carta ;
    sh:name "Has cartas" ;
    sh:path prueba:hasCartas ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://tu-dominio.com/ontologia/prueba#hasCartas> ?that . ?that <http://tu-dominio.com/ontologia/prueba#hasCartas> ?this .}" ] .

core-shape:prueba-JuegoDeCartas-prueba-hasId a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has id" ;
    sh:path prueba:hasId .

core-shape:prueba-JuegoDeCartas-prueba-hasJuego a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class prueba:Juego ;
    sh:name "Has juego" ;
    sh:path prueba:hasJuego .

core-shape:prueba-JuegoDeCartas-prueba-hasNombre a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has nombre" ;
    sh:path prueba:hasNombre .

core-shape:prueba-Jugador-prueba-hasEsPropietario a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class prueba:InstanciaCarta ;
    sh:name "Has es propietario" ;
    sh:path prueba:hasEsPropietario ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://tu-dominio.com/ontologia/prueba#hasEsPropietario> ?that . ?that <http://tu-dominio.com/ontologia/prueba#hasEsPropietario> ?this .}" ] .

core-shape:prueba-Partida-prueba-hasJugadores a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class prueba:Jugador ;
    sh:minCount 1 ;
    sh:name "Has jugadores" ;
    sh:path prueba:hasJugadores ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://tu-dominio.com/ontologia/prueba#hasJugadores> ?that . ?that <http://tu-dominio.com/ontologia/prueba#hasJugadores> ?this .}" ] .

core-shape:prueba-Partida-prueba-hasPartidaDeJuego a sh:PropertyShape ;
    rdfs:isDefinedBy core-shape:core-shape ;
    sh:class prueba:JuegoDeCartas ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "Has partida de juego" ;
    sh:path prueba:hasPartidaDeJuego ;
    sh:sparql [ sh:select "SELECT ?this ?that WHERE { ?this <http://tu-dominio.com/ontologia/prueba#hasPartidaDeJuego> ?that . ?that <http://tu-dominio.com/ontologia/prueba#hasPartidaDeJuego> ?this .}" ] .

