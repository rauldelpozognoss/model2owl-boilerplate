@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prueba: <http://tu-dominio.com/ontologia/prueba#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

prueba:core-restriction a owl:Ontology ;
    rdfs:label "Restricciones de la ontología de prueba."@en ;
    dcterms:created "2026-03-24"^^xsd:date ;
    dcterms:description "Restricciones de la ontología de prueba."@en ;
    dcterms:issued "2026-03-25"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://tu-dominio.com" ;
    dcterms:title "Ontología de Prueba Restricciones"@en ;
    vann:preferredNamespacePrefix "prueba" ;
    vann:preferredNamespaceUri "http://tu-dominio.com/ontologia/prueba#" ;
    rdfs:comment """This version is automatically generated from prueba.xml on 
                2026-03-25""" ;
    rdfs:seeAlso <https://github.com/tu-usuario/tu-repo> ;
    owl:imports dcterms:,
        prueba:core,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://tu-dominio.com/ontologia/prueba#core-restriction-" ;
    owl:versionIRI prueba:core-restriction-1.0.0 ;
    owl:versionInfo "1.0.0" .

prueba:hasCartas rdfs:domain prueba:JuegoDeCartas ;
    rdfs:range prueba:Carta .

prueba:hasEsPropietario rdfs:domain prueba:Jugador ;
    rdfs:range prueba:InstanciaCarta .

prueba:hasJugadores rdfs:domain prueba:Partida ;
    rdfs:range prueba:Jugador .

prueba:hasPartidaDeJuego rdfs:domain prueba:Partida ;
    rdfs:range prueba:JuegoDeCartas .

prueba:hasTipoCarta rdfs:domain prueba:Carta ;
    rdfs:range prueba:TipoCarta .

prueba:Juego rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasComponentes ;
            owl:qualifiedCardinality 1 ] .

prueba:hasAtaque a owl:FunctionalProperty ;
    rdfs:domain prueba:Stats ;
    rdfs:range xsd:string .

prueba:hasComponentes a owl:FunctionalProperty ;
    rdfs:domain prueba:Juego ;
    rdfs:range xsd:string .

prueba:hasDefensa a owl:FunctionalProperty ;
    rdfs:domain prueba:Stats ;
    rdfs:range xsd:string .

prueba:hasDni a owl:FunctionalProperty ;
    rdfs:domain prueba:Jugador ;
    rdfs:range xsd:string .

prueba:hasFechaNacimiento a owl:FunctionalProperty ;
    rdfs:domain prueba:Jugador ;
    rdfs:range xsd:string .

prueba:hasFechaSalida a owl:FunctionalProperty ;
    rdfs:domain prueba:Carta ;
    rdfs:range xsd:string .

prueba:hasImagen a owl:FunctionalProperty ;
    rdfs:domain prueba:InstanciaCarta ;
    rdfs:range xsd:string .

prueba:hasStats a owl:FunctionalProperty ;
    rdfs:domain prueba:InstanciaCarta ;
    rdfs:range xsd:string .

prueba:hasVersion a owl:FunctionalProperty ;
    rdfs:domain prueba:InstanciaCarta ;
    rdfs:range xsd:string .

prueba:Stats rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasAtaque ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasDefensa ;
            owl:qualifiedCardinality 1 ] .

prueba:hasId a owl:FunctionalProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( prueba:InstanciaCarta prueba:JuegoDeCartas ) ] ;
    rdfs:range xsd:string .

prueba:hasNombre a owl:FunctionalProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( prueba:Jugador prueba:Carta prueba:JuegoDeCartas ) ] ;
    rdfs:range xsd:string .

prueba:Carta rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasNombre ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasFechaSalida ;
            owl:qualifiedCardinality 1 ] .

prueba:JuegoDeCartas rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasNombre ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasId ;
            owl:qualifiedCardinality 1 ] .

prueba:InstanciaCarta rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasStats ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasImagen ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasId ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasVersion ;
            owl:qualifiedCardinality 1 ] .

prueba:Jugador rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasFechaNacimiento ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasDni ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasNombre ;
            owl:qualifiedCardinality 1 ] .

