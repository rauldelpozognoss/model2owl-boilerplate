@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prueba: <http://tu-dominio.com/ontologia/prueba#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

prueba:core-restriction a owl:Ontology ;
    rdfs:label "Restricciones de la ontología de prueba."@en ;
    dcterms:created "2026-03-24"^^xsd:date ;
    dcterms:description "Restricciones de la ontología de prueba."@en ;
    dcterms:issued "2026-03-25"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://tu-dominio.com" ;
    dcterms:title "Ontología de Prueba Restricciones"@en ;
    vann:preferredNamespacePrefix "prueba" ;
    vann:preferredNamespaceUri "http://tu-dominio.com/ontologia/prueba#" ;
    rdfs:comment """This version is automatically generated from prueba.xml on 
                2026-03-25""" ;
    rdfs:seeAlso <https://github.com/tu-usuario/tu-repo> ;
    owl:imports dcterms:,
        prueba:core,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://tu-dominio.com/ontologia/prueba#core-restriction-" ;
    owl:versionIRI prueba:core-restriction-1.0.0 ;
    owl:versionInfo "1.0.0" .

prueba:hasAdjudicatario a owl:FunctionalProperty ;
    rdfs:domain prueba:Contrato ;
    rdfs:range prueba:Adjudicatario .

prueba:hasNombre a owl:FunctionalProperty ;
    rdfs:domain prueba:Adjudicatario ;
    rdfs:range xsd:string .

prueba:hasTitulo a owl:FunctionalProperty ;
    rdfs:domain prueba:Contrato ;
    rdfs:range xsd:string .

prueba:Contrato rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasTitulo ;
            owl:qualifiedCardinality 1 ],
        [ a owl:Restriction ;
            owl:onClass prueba:Adjudicatario ;
            owl:onProperty prueba:hasAdjudicatario ;
            owl:qualifiedCardinality 1 ] .

prueba:Adjudicatario rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty prueba:hasNombre ;
            owl:qualifiedCardinality 1 ] .

