@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prueba: <http://tu-dominio.com/ontologia/prueba#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

prueba:Adjudicatario a owl:Class ;
    rdfs:isDefinedBy prueba:core ;
    skos:definition "La entidad a la que se le ha adjudicado el contrato."@en ;
    skos:prefLabel "Adjudicatario"@en .

prueba:Contrato a owl:Class ;
    rdfs:isDefinedBy prueba:core ;
    skos:definition "Un contrato formalizado en el proceso de adjudicación."@en ;
    skos:prefLabel "Contrato"@en .

prueba:hasAdjudicatario a owl:ObjectProperty ;
    rdfs:isDefinedBy prueba:core ;
    skos:prefLabel "has Adjudicatario"@en .

prueba:hasNombre a owl:DatatypeProperty ;
    rdfs:isDefinedBy prueba:core ;
    skos:definition "Nombre oficial de la entidad adjudicataria. (prueba:Adjudicatario)"@en ;
    skos:prefLabel "has Nombre"@en .

prueba:hasTitulo a owl:DatatypeProperty ;
    rdfs:isDefinedBy prueba:core ;
    skos:definition "El título o nombre descriptivo del contrato. (prueba:Contrato)"@en ;
    skos:prefLabel "has Titulo"@en .

prueba:core a owl:Ontology ;
    rdfs:label "Esta es mi primera ontología de prueba generada desde Modelio."@en ;
    dcterms:created "2026-03-24"^^xsd:date ;
    dcterms:description "Esta es mi primera ontología de prueba generada desde Modelio."@en ;
    dcterms:issued "2026-03-25"^^xsd:date ;
    dcterms:license "CC BY 4.0" ;
    dcterms:publisher "http://tu-dominio.com" ;
    dcterms:title "Ontología de Prueba Core"@en ;
    vann:preferredNamespacePrefix "prueba" ;
    vann:preferredNamespaceUri "http://tu-dominio.com/ontologia/prueba#" ;
    rdfs:comment "This version is automatically generated from prueba.xml on 2026-03-25" ;
    rdfs:seeAlso <https://github.com/tu-usuario/tu-repo> ;
    owl:imports dcterms:,
        skos: ;
    owl:incompatibleWith "" ;
    owl:priorVersion "http://tu-dominio.com/ontologia/prueba#core-" ;
    owl:versionIRI prueba:core-1.0.0 ;
    owl:versionInfo "1.0.0" .

